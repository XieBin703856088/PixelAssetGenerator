{
  "formatVersion": 2,
  "processorType": "ParticleTrail",
  "identity": {
    "typeName": "ParticleTrail",
    "displayName": {
      "zh-Hans": "粒子拖尾",
      "en": "Particle Trail"
    },
    "category": "Particle",
    "description": {
      "zh-Hans": "在粒子运动路径上生成拖尾残影效果，每个粒子的旧位置产生逐渐淡出的影子粒子",
      "en": "Generates trailing afterimage effects along particle motion paths, creating fading ghost particles at each particle's old positions"
