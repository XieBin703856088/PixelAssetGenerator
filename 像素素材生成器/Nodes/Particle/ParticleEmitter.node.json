{
  "formatVersion": 2,
  "processorType": "ParticleEmitter",
  "identity": {
    "typeName": "ParticleEmitter",
    "displayName": { "zh-Hans": "粒子发射器", "en": "Particle Emitter" },
    "category": "Particle",
    "description": {
      "zh-Hans": "从可动画的位置发射像素粒子，并输出可连接力场、碰撞和渲染节点的粒子流。",
      "en": "Emits pixel particles from an animatable position and outputs a stream for forces, collisions and render nodes."
    },
    "tags": ["particle", "emitter", "animation"],
    "author": "BuiltIn",
    "version": "2.0"
  },
  "ports": {
    "inputs": [
      { "name": { "zh-Hans": "遮罩", "en": "Mask" }, "type": "Mask" },
      { "name": { "zh-Hans": "位置 X", "en": "Position X" }, "type": "Float" },
      { "name": { "zh-Hans": "位置 Y", "en": "Position Y" }, "type": "Float" },
      { "name": { "zh-Hans": "发射率", "en": "Emission Rate" }, "type": "Float" },
      { "name": { "zh-Hans": "速度", "en": "Speed" }, "type": "Float" },
      { "name": { "zh-Hans": "大小", "en": "Size" }, "type": "Float" }
    ],
    "outputs": [
      { "name": { "zh-Hans": "粒子", "en": "Particles" }, "type": "Particle" }
    ]
  },
  "parameters": [
    {
      "name": { "zh-Hans": "效果预设", "en": "Effect Preset" },
      "kind": "Choice",
      "default": "manual",
      "choices": ["manual", "fire", "smoke", "rain", "snow", "sparks", "magic", "dust", "explosion", "bubbles", "leaves"],
      "displayChoices": ["手动", "火焰", "烟雾", "雨水", "雪花", "火花", "魔法", "尘土", "爆炸", "气泡", "落叶"]
    },
    { "name": { "zh-Hans": "预设强度", "en": "Preset Intensity" }, "kind": "Number", "default": 1.0, "min": 0.1, "max": 4.0, "step": 0.05 },
    { "name": { "zh-Hans": "预设尺寸", "en": "Preset Scale" }, "kind": "Number", "default": 1.0, "min": 0.25, "max": 4.0, "step": 0.05 },
    { "name": { "zh-Hans": "发射率", "en": "Emission Rate" }, "kind": "Number", "default": 50, "min": 0, "max": 500, "step": 1 },
    { "name": { "zh-Hans": "爆发数量", "en": "Burst Count" }, "kind": "Integer", "default": 20, "min": 0, "max": 200, "step": 1 },
    { "name": { "zh-Hans": "粒子寿命", "en": "Lifespan" }, "kind": "Number", "default": 2.0, "min": 0.1, "max": 10, "step": 0.1 },
    { "name": { "zh-Hans": "寿命随机", "en": "Life Random" }, "kind": "Number", "default": 0.15, "min": 0, "max": 1, "step": 0.01 },
    { "name": { "zh-Hans": "速度", "en": "Speed" }, "kind": "Number", "default": 0.3, "min": 0.0, "max": 2.0, "step": 0.01 },
    { "name": { "zh-Hans": "速度随机", "en": "Speed Random" }, "kind": "Number", "default": 0.5, "min": 0, "max": 1.0, "step": 0.01 },
    { "name": { "zh-Hans": "发射角度", "en": "Angle" }, "kind": "Number", "default": 270, "min": 0, "max": 360, "step": 1 },
    { "name": { "zh-Hans": "扩散角度", "en": "Spread" }, "kind": "Number", "default": 30, "min": 0, "max": 360, "step": 1 },
    { "name": { "zh-Hans": "位置 X", "en": "Position X" }, "kind": "Number", "default": 0.5, "min": 0, "max": 1.0, "step": 0.01 },
    { "name": { "zh-Hans": "位置 Y", "en": "Position Y" }, "kind": "Number", "default": 0.5, "min": 0, "max": 1.0, "step": 0.01 },
    { "name": { "zh-Hans": "起始大小", "en": "Start Size" }, "kind": "Number", "default": 0.05, "min": 0.005, "max": 0.5, "step": 0.005 },
    { "name": { "zh-Hans": "结束大小", "en": "End Size" }, "kind": "Number", "default": 0.01, "min": 0, "max": 0.5, "step": 0.005 },
    { "name": { "zh-Hans": "大小随机", "en": "Size Random" }, "kind": "Number", "default": 0.15, "min": 0, "max": 1, "step": 0.01 },
    { "name": { "zh-Hans": "起始颜色", "en": "Start Color" }, "kind": "Color", "default": "#FFFFFFFF" },
    { "name": { "zh-Hans": "结束颜色", "en": "End Color" }, "kind": "Color", "default": "#00FFFFFF" },
    { "name": { "zh-Hans": "重力", "en": "Gravity" }, "kind": "Number", "default": 0.2, "min": -1.0, "max": 1.0, "step": 0.01 },
    { "name": { "zh-Hans": "横向重力", "en": "Gravity X" }, "kind": "Number", "default": 0, "min": -2.0, "max": 2.0, "step": 0.01 },
    { "name": { "zh-Hans": "阻尼", "en": "Damping" }, "kind": "Number", "default": 0.98, "min": 0.0, "max": 1.0, "step": 0.005 },
    { "name": { "zh-Hans": "单次爆发", "en": "One Shot" }, "kind": "Boolean", "default": false },
    { "name": { "zh-Hans": "平铺循环", "en": "Tiling" }, "kind": "Boolean", "default": true },
    { "name": { "zh-Hans": "风力", "en": "Wind" }, "kind": "Number", "default": 0, "min": -1.0, "max": 1.0, "step": 0.01 },
    { "name": { "zh-Hans": "纵向风力", "en": "Wind Y" }, "kind": "Number", "default": 0, "min": -1.0, "max": 1.0, "step": 0.01 },
    { "name": { "zh-Hans": "预热模拟", "en": "Prewarm" }, "kind": "Boolean", "default": true },
    { "name": { "zh-Hans": "预热秒数", "en": "Prewarm Seconds" }, "kind": "Number", "default": 0.35, "min": 0, "max": 5, "step": 0.05 },
    { "name": { "zh-Hans": "最大粒子数", "en": "Max Particles" }, "kind": "Integer", "default": 500, "min": 1, "max": 10000, "step": 1 },
    { "name": { "zh-Hans": "发射形状", "en": "Emission Shape" }, "kind": "Choice", "default": "point", "choices": ["point", "line", "rectangle", "circle", "ring"] },
    { "name": { "zh-Hans": "形状宽度", "en": "Shape Width" }, "kind": "Number", "default": 0.1, "min": 0, "max": 1.0, "step": 0.01 },
    { "name": { "zh-Hans": "形状高度", "en": "Shape Height" }, "kind": "Number", "default": 0.1, "min": 0, "max": 1.0, "step": 0.01 },
    { "name": { "zh-Hans": "随机旋转", "en": "Random Rotation" }, "kind": "Number", "default": 3.14, "min": 0, "max": 6.28, "step": 0.01 },
    { "name": { "zh-Hans": "随机角速度", "en": "Angular Vel. Random" }, "kind": "Number", "default": 0, "min": 0, "max": 10, "step": 0.1 }
  ],
  "ai": {
    "capabilities": ["particle", "emitter", "animation"],
    "triggers": {
      "zh-Hans": "粒子发射器, 粒子系统, 粒子爆发, 动画发射位置",
      "en": "particle emitter, particle system, particle burst, animated emitter position"
    },
    "suggestedInputs": ["Time", "Wave", "AnimationPath"],
    "exampleUsage": {
      "zh-Hans": "将动画路径的 X/Y 输出连接到位置端口，再连接力场与粒子渲染节点。",
      "en": "Connect Animation Path X/Y to position ports, then connect forces and Particle Render."
    }
  }
}
