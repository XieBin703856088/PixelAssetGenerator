{
  "formatVersion": 2,
  "processorType": "AnimationPath",
  "identity": {
    "typeName": "AnimationPath",
    "displayName": {
      "zh-Hans": "动画路径",
      "en": "Animation Path"
    },
    "category": "Animation",
    "description": {
      "zh-Hans": "定义2D运动路径（Catmull-Rom样条/折线/贝塞尔曲线），输出路径上的位置和角度",
      "en": "Defines a 2D motion path (Catmull-Rom spline/polyline/Bezier curve), outputs position and angle along the path"
    },
    "tags": ["animation", "path", "motion"],
    "author": "BuiltIn",
    "version": "1.0"
  },
  "ports": {
    "inputs": [],
    "outputs": [
      {
        "name": { "zh-Hans": "位置X", "en": "PositionX" },
        "type": "Float"
      },
      {
        "name": { "zh-Hans": "位置Y", "en": "PositionY" },
        "type": "Float"
      },
      {
        "name": { "zh-Hans": "角度", "en": "Angle" },
        "type": "Float"
      }
    ]
  },
  "parameters": [
    { "name": { "zh-Hans": "路径持续时间", "en": "Duration" }, "kind": "Number", "default": 2.0, "min": 0.1, "max": 30.0, "step": 0.1 },
    { "name": { "zh-Hans": "循环", "en": "Loop" }, "kind": "Boolean", "default": true },
    {
      "name": { "zh-Hans": "路径类型", "en": "Path Type" },
      "kind": "Choice",
      "default": "catmullRom",
      "choices": ["catmullRom", "polyline", "bezier"],
      "displayChoices": ["Catmull-Rom样条", "折线", "贝塞尔"]
    },
    { "name": { "zh-Hans": "控制点数量", "en": "Point Count" }, "kind": "Integer", "default": 4, "min": 2, "max": 16, "step": 1 },
    { "name": { "zh-Hans": "平滑度", "en": "Smoothness" }, "kind": "Number", "default": 0.5, "min": 0.0, "max": 1.0, "step": 0.05 }
  ],
  "ai": {
    "capabilities": ["animation", "parameter-animation"],
    "triggers": {
      "zh-Hans": "运动路径, 样条路径, 贝塞尔曲线, 物体移动轨迹",
      "en": "motion path, spline path, bezier curve, object movement trajectory"
    },
    "suggestedInputs": ["AnimatedParameter", "Time"],
    "exampleUsage": {
      "zh-Hans": "创建一条4个控制点的Catmull-Rom样条路径，使物体在2秒内沿路径循环运动",
      "en": "Create a Catmull-Rom spline path with 4 control points for a looping 2-second motion"
    }
  }
}
