    { "name": { "zh-Hans": "循环", "en": "Loop" }, "kind": "Boolean", "default": true },
    { "name": { "zh-Hans": "关键帧数", "en": "Keyframe Count" }, "kind": "Integer", "default": 2, "min": 2, "max": 10, "step": 1 },

