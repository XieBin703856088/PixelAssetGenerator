{
  "formatVersion": 2,
  "processorType": "AnimatedParameter",
  "identity": {
    "typeName": "AnimatedParameter",
    "displayName": {
      "zh-Hans": "参数动画",
      "en": "Animated Parameter"
    },
    "category": "Animation",
    "description": {
      "zh-Hans": "通过关键帧输出随时间变化的动画值，可连接到其他节点参数。支持最多10个关键帧，每个关键帧可配置时间、值和缓动类型。缓出适合自然减速，弹跳/弹性适合生动效果。",
      "en": "Outputs animated values over time via keyframes, connectable to other node parameters. Supports up to 10 keyframes with per-keyframe time, value, and easing type. Ease out for natural deceleration, bounce/elastic for lively effects."
    },
    "tags": ["animation", "parameter"],
    "author": "BuiltIn",
    "version": "1.1"
  },
  "ports": {
    "inputs": [],
    "outputs": [
      {
        "name": { "zh-Hans": "值", "en": "Value" },
        "type": "Float"
      }
    ]
  },
