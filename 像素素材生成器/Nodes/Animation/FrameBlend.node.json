{
  "formatVersion": 2,
  "processorType": "FrameBlend",
  "identity": {
    "typeName": "FrameBlend",
    "displayName": {
      "zh-Hans": "帧混合",
      "en": "Frame Blend"
    },
    "category": "Animation",
    "description": {
      "zh-Hans": "在两个输入帧之间混合，支持多种混合模式",
      "en": "Blends between two input frames with multiple blend modes"
    },
    "tags": ["animation", "blend"],
    "author": "BuiltIn",
    "version": "1.0"
  },
  "ports": {
    "inputs": [
      {
        "name": { "zh-Hans": "帧A", "en": "Frame A" },
        "type": "Image"
      },
      {
        "name": { "zh-Hans": "帧B", "en": "Frame B" },
        "type": "Image"
      },
      {
        "name": { "zh-Hans": "混合值", "en": "Blend" },
        "type": "Float"
      }
    ],
    "outputs": [
      {
        "name": { "zh-Hans": "图像", "en": "Image" },
        "type": "Image"
      }
    ]
  },
  "parameters": [
    {
      "name": { "zh-Hans": "混合模式", "en": "Blend Mode" },
      "kind": "Choice",
      "default": "crossFade",
      "choices": ["crossFade", "add", "difference", "multiply", "screen"]
    },
    { "name": { "zh-Hans": "默认混合值", "en": "Default Blend" }, "kind": "Number", "default": 0.5, "min": 0, "max": 1, "step": 0.01 }
  ],
  "ai": {
    "capabilities": ["animation", "frame-blend"],
    "triggers": {
      "zh-Hans": "帧混合, 图像混合, 过渡效果, 混合模式",
      "en": "frame blend, image blend, transition effect, blend mode"
    },
    "suggestedInputs": ["AnimatedParameter", "Time"],
    "exampleUsage": {
      "zh-Hans": "在帧A和帧B之间用交叉淡入淡出混合，用参数动画控制混合值从0到1",
      "en": "Cross-fade between Frame A and Frame B, use Animated Parameter to drive blend from 0 to 1"
    }
  }
}
