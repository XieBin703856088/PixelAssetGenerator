<Window x:Class="PixelAssetGenerator.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:PixelAssetGenerator.Services.Localization"
        Title="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ColorPicker_Title]}" Width="300" Height="410"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PrimaryText}"
        FontFamily="{DynamicResource AppFontFamily}">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Color wheel canvas ───────────────────────────────────────── -->
        <!--   Hue ring (outer) + SV square (inner, centered)               -->
        <!--   Canvas is 220×220; ring outerR=106, innerR=78               -->
        <!--   SV square is 110×110 offset (55,55) so corners touch innerR  -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10"
                HorizontalAlignment="Center">
        <Canvas
                x:Name="ColorCanvas"
                Width="220" Height="220"
                HorizontalAlignment="Center"
                Background="Transparent"
                MouseLeftButtonDown="ColorCanvas_MouseDown"
                MouseLeftButtonUp="ColorCanvas_MouseUp"
                MouseMove="ColorCanvas_MouseMove">

            <!-- Hue ring bitmap (full canvas size) -->
            <Image x:Name="HueRingImage"
                   Width="220" Height="220"
                   Canvas.Left="0" Canvas.Top="0" />

            <!-- SV (saturation–value) square bitmap, centered inside ring -->
            <Image x:Name="SvSquareImage"
                   Width="110" Height="110"
                   Canvas.Left="55" Canvas.Top="55" />

            <!-- Hue-ring selector: black shadow ring + white visible ring -->
            <Ellipse x:Name="HueSelectorOuter"
                     Width="14" Height="14"
                     Stroke="Black" StrokeThickness="1"
                     Fill="Transparent"
                     Panel.ZIndex="9" />
            <Ellipse x:Name="HueSelector"
                     Width="14" Height="14"
                     Stroke="White" StrokeThickness="2"
                     Fill="Transparent"
                     Panel.ZIndex="10" />

            <!-- SV-square selector: black shadow + white ring -->
            <Ellipse x:Name="SvSelectorOuter"
                     Width="10" Height="10"
                     Stroke="Black" StrokeThickness="2"
                     Fill="Transparent"
                     Panel.ZIndex="9" />
            <Ellipse x:Name="SvSelector"
                     Width="10" Height="10"
                     Stroke="White" StrokeThickness="1"
                     Fill="Transparent"
                     Panel.ZIndex="10" />
        </Canvas>
        </Border>

        <!-- ── Hex input ────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ColorPicker_Hex]}" VerticalAlignment="Center"
                       Margin="0,0,8,0" FontSize="11" />
            <TextBox Grid.Column="1" x:Name="HexTextBox"
                     LostFocus="HexTextBox_LostFocus"
                     KeyDown="HexTextBox_KeyDown" />
        </Grid>

        <!-- ── Preview swatch + action buttons ─────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Border x:Name="PreviewBorder"
                    Width="40" Height="28"
                    CornerRadius="3"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1"
                    Margin="0,0,10,0" />
            <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ColorPicker_Cancel]}" MinWidth="96" Margin="0,0,8,0"
                    IsCancel="True" Click="Cancel_Click" />
            <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ColorPicker_OK]}" MinWidth="96"
                    IsDefault="True" Click="OK_Click" Style="{StaticResource AccentButton}" />
        </StackPanel>
    </Grid>
</Window>
