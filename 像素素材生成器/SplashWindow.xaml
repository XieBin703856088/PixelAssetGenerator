<Window x:Class="PixelAssetGenerator.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:PixelAssetGenerator.Services.Localization"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True"
        Width="520" Height="400"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Loaded="Window_Loaded"
        FontFamily="Segoe UI Variable, Microsoft YaHei UI, Segoe UI">

    <Grid>
        <!-- Main panel -->
        <Border Width="480" Height="360"
                CornerRadius="14"
                Background="#11101B"
                BorderBrush="#312B4C"
                BorderThickness="2">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.7" BlurRadius="32" ShadowDepth="0" />
            </Border.Effect>

            <Grid ClipToBounds="True">
                <!-- Animated pixel grid background -->
                <Border x:Name="BgPatternHost"
                        Width="960" Height="720"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Opacity="0.35">
                    <Border.Background>
                        <DrawingBrush x:Name="BgPatternBrush"
                                      Stretch="None"
                                      AlignmentX="Left"
                                      AlignmentY="Top"
                                      TileMode="Tile"
                                      Viewport="0,0,32,32"
                                      ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Geometry="M 0,0 L 32,0">
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="#2C2545" Thickness="1" />
                                        </GeometryDrawing.Pen>
                                    </GeometryDrawing>
                                    <GeometryDrawing Geometry="M 0,0 L 0,32">
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="#2C2545" Thickness="1" />
                                        </GeometryDrawing.Pen>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Border.Background>
                </Border>

                <!-- Scrolling pixel-dots layer -->
                <Border x:Name="BgDotHost"
                        Width="960" Height="720"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Opacity="0.15">
                    <Border.Background>
                        <DrawingBrush x:Name="BgDotBrush"
                                      Stretch="None"
                                      AlignmentX="Left"
                                      AlignmentY="Top"
                                      TileMode="Tile"
                                      Viewport="0,0,64,64"
                                      ViewportUnits="Absolute">
                            <DrawingBrush.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Geometry="M 16,16 L 18,16 L 18,18 L 16,18 Z"
                                                     Brush="#8B5CF6" />
                                    <GeometryDrawing Geometry="M 48,48 L 50,48 L 50,50 L 48,50 Z"
                                                     Brush="#5B3EA8" />
                                </DrawingGroup>
                            </DrawingBrush.Drawing>
                        </DrawingBrush>
                    </Border.Background>
                </Border>

                <!-- Corner decorations (pixel-art style brackets) -->
                <Path Stroke="#2A4A78" StrokeThickness="2" Fill="Transparent"
                      Data="M 16,40 L 16,16 L 40,16" />
                <Path Stroke="#2A4A78" StrokeThickness="2" Fill="Transparent"
                      Data="M 464,40 L 464,16 L 440,16" />
                <Path Stroke="#2A4A78" StrokeThickness="2" Fill="Transparent"
                      Data="M 16,320 L 16,344 L 40,344" />
                <Path Stroke="#2A4A78" StrokeThickness="2" Fill="Transparent"
                      Data="M 464,320 L 464,344 L 440,344" />

                <Grid Margin="40,32,40,28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- ═══════ Logo area ═══════ -->
                    <Grid Grid.Row="0"
                          HorizontalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Pixel-cube logo -->
                        <Canvas x:Name="LogoCanvas" Grid.Row="0"
                                Width="64" Height="64"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,10"
                                RenderTransformOrigin="0.5,0.5">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                    <TranslateTransform X="0" Y="0" />
                                </TransformGroup>
                            </Canvas.RenderTransform>
                            <!-- Isometric pixel cube: top face -->
                            <Polygon Points="32,2 58,16 32,30 6,16"
                             Fill="#9B72F2" Stroke="#B99AF8" StrokeThickness="1"
                                     StrokeLineJoin="Round" />
                            <!-- left face -->
                            <Polygon Points="6,16 6,44 32,58 32,30"
                             Fill="#7650C6" Stroke="#9B72F2" StrokeThickness="1"
                                     StrokeLineJoin="Round" />
                            <!-- right face -->
                            <Polygon Points="32,30 32,58 58,44 58,16"
                             Fill="#51358F" Stroke="#7650C6" StrokeThickness="1"
                                     StrokeLineJoin="Round" />
                            <!-- highlight pixel dots -->
                            <Rectangle Canvas.Left="18" Canvas.Top="22" Width="2" Height="2" Fill="#8AC0FF" Opacity="0.8" />
                            <Rectangle Canvas.Left="36" Canvas.Top="12" Width="2" Height="2" Fill="#8AC0FF" Opacity="0.6" />
                            <Rectangle Canvas.Left="44" Canvas.Top="20" Width="2" Height="2" Fill="#8AC0FF" Opacity="0.4" />
                            <!-- scanning line animation overlay -->
                            <Rectangle x:Name="ScanLine" Canvas.Left="4" Canvas.Top="4"
                                       Width="56" Height="2" Fill="#8AC0FF" Opacity="0.4" />
                        </Canvas>

                        <!-- Title -->
                        <TextBlock x:Name="TitleBlock" Grid.Row="1"
                                   HorizontalAlignment="Center"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="#F4F1FF"
                                   TextOptions.TextFormattingMode="Display"
                                   Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Splash_Title]}" />
                        <TextBlock Grid.Row="2"
                                   Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Splash_Subtitle]}"
                                   Foreground="#9F8BC7"
                                   FontSize="10" FontWeight="Medium"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0" />
                    </Grid>

                    <!-- Spacer -->
                    <Grid Grid.Row="1" />

                    <!-- ═══════ Loading section ═══════ -->
                    <Border Grid.Row="2"
                            Background="#0D0C15"
                            BorderBrush="#312B4C"
                            BorderThickness="1"
                            CornerRadius="2"
                            Padding="0,0,0,0"
                            Margin="0,0,0,8">
                        <Grid Margin="0,0,0,0">
                            <Border x:Name="PixelBarBg"
                                    Height="14"
                                    Background="#1B1828"
                                    CornerRadius="2"
                                    Margin="0" />
                            <!-- Progress fill - stepped/pixelated look -->
                            <Border x:Name="ProgressFillBorder"
                                    Width="0" Height="14"
                                    CornerRadius="2"
                                    HorizontalAlignment="Left">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Offset="0.0" Color="#7650C6" />
                                        <GradientStop Offset="0.5" Color="#8B5CF6" />
                                        <GradientStop Offset="1.0" Color="#A982FF" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <!-- Grid overlay to create pixel-step effect -->
                            <Rectangle x:Name="PixelGridOverlay"
                                       Fill="Transparent"
                                       Stroke="#0B0E14"
                                       StrokeThickness="0"
                                       Opacity="0.15"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       IsHitTestVisible="False" />
                        </Grid>
                    </Border>

                    <!-- Status text -->
                    <TextBlock x:Name="StatusTextBlock"
                               Grid.Row="3"
                               Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[Splash_Initializing]}"
                               Foreground="#5A7AAA"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,2" />

                    <!-- Bottom row: detail + percent -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DetailTextBlock"
                                   Grid.Column="0"
                                   Text=""
                                   Foreground="#3A4A6A"
                                   FontSize="10" />
                        <TextBlock x:Name="PercentTextBlock"
                                   Grid.Column="1"
                                   Text="0%"
                                   Foreground="#4A6A9A"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   FontFamily="Consolas" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
