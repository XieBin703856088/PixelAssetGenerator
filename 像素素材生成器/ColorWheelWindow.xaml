<Window x:Class="PixelAssetGenerator.ColorWheelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:PixelAssetGenerator.Services.Localization"
        Title="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ColorWheel_Title]}"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PrimaryText}"
        FontFamily="{DynamicResource AppFontFamily}"
        Loaded="Window_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ===== 色环 + SV 方块 ===== -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="14"
                Margin="0,0,0,16"
                HorizontalAlignment="Center">
            <Canvas x:Name="WheelCanvas"
                    Width="280" Height="280"
                    Background="Transparent"
                    ClipToBounds="True"
                    Cursor="Cross"
                    MouseLeftButtonDown="WheelCanvas_MouseLeftButtonDown"
                    MouseMove="WheelCanvas_MouseMove"
                    MouseLeftButtonUp="WheelCanvas_MouseLeftButtonUp">
                <!-- 色相环位图 -->
                <Image x:Name="HueRingImage"
                       Width="280" Height="280"
                       IsHitTestVisible="False"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <!-- SV 方块位图 -->
                <Image x:Name="SVSquareImage"
                       IsHitTestVisible="False"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <!-- SV 方块边框 -->
                <Border x:Name="SVSquareBorder"
                        BorderBrush="{DynamicResource ControlBorder}"
                        BorderThickness="0.5"
                        IsHitTestVisible="False" />
                <!-- 色相环选择标记 -->
                <Ellipse x:Name="RingMarker"
                         Width="18" Height="18"
                         Stroke="White"
                         StrokeThickness="2.5"
                         IsHitTestVisible="False">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="0" Opacity="0.8" />
                    </Ellipse.Effect>
                </Ellipse>
                <!-- SV 选择标记 -->
                <Ellipse x:Name="SVMarker"
                         Width="14" Height="14"
                         Stroke="White"
                         StrokeThickness="2"
                         Fill="Transparent"
                         IsHitTestVisible="False">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="0" Opacity="0.9" />
                    </Ellipse.Effect>
                </Ellipse>
            </Canvas>
        </Border>

        <!-- ===== 预览 + HEX ===== -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ColorWheel_Preview]}" FontSize="10"
                           Foreground="{DynamicResource MutedText}"
                           Margin="0,0,0,3" />
                <Border Width="64" Height="48"
                        BorderBrush="{DynamicResource ControlBorder}"
                        BorderThickness="1"
                        CornerRadius="4"
                        ClipToBounds="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Rectangle x:Name="OldColorRect" Grid.Column="0" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ColorWheel_OldColor]}" />
                        <Rectangle x:Name="NewColorRect" Grid.Column="1" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ColorWheel_NewColor]}" />
                    </Grid>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ColorWheel_HEX]}" FontSize="10"
                           Foreground="{DynamicResource MutedText}"
                           Margin="0,0,0,3" />
                <TextBox x:Name="HexTextBox"
                          MinHeight="36"
                         FontSize="13"
                         FontFamily="Consolas"
                         VerticalContentAlignment="Center"
                         Padding="6,2"
                         KeyDown="HexTextBox_KeyDown"
                         LostFocus="HexTextBox_LostFocus" />
            </StackPanel>
        </Grid>

        <!-- ===== R G B ===== -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="R" FontSize="10" Foreground="#FF6B6B" Margin="0,0,0,2" />
                <TextBox x:Name="RTextBox" MinHeight="34" FontSize="12"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"
                         KeyDown="RGBTextBox_KeyDown"
                         LostFocus="RGBTextBox_LostFocus" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="G" FontSize="10" Foreground="#6BFF6B" Margin="0,0,0,2" />
                <TextBox x:Name="GTextBox" MinHeight="34" FontSize="12"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"
                         KeyDown="RGBTextBox_KeyDown"
                         LostFocus="RGBTextBox_LostFocus" />
            </StackPanel>
            <StackPanel Grid.Column="4">
                <TextBlock Text="B" FontSize="10" Foreground="#6B9FFF" Margin="0,0,0,2" />
                <TextBox x:Name="BTextBox" MinHeight="34" FontSize="12"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"
                         KeyDown="RGBTextBox_KeyDown"
                         LostFocus="RGBTextBox_LostFocus" />
            </StackPanel>
        </Grid>

        <!-- ===== H S V ===== -->
        <Grid Grid.Row="3" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="H°" FontSize="10"
                           Foreground="{DynamicResource MutedText}"
                           Margin="0,0,0,2" />
                <TextBox x:Name="HTextBox" MinHeight="34" FontSize="12"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"
                         KeyDown="HSVTextBox_KeyDown"
                         LostFocus="HSVTextBox_LostFocus" />
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="S%" FontSize="10"
                           Foreground="{DynamicResource MutedText}"
                           Margin="0,0,0,2" />
                <TextBox x:Name="STextBox" MinHeight="34" FontSize="12"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"
                         KeyDown="HSVTextBox_KeyDown"
                         LostFocus="HSVTextBox_LostFocus" />
            </StackPanel>
            <StackPanel Grid.Column="4">
                <TextBlock Text="V%" FontSize="10"
                           Foreground="{DynamicResource MutedText}"
                           Margin="0,0,0,2" />
                <TextBox x:Name="VTextBox" MinHeight="34" FontSize="12"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"
                         KeyDown="HSVTextBox_KeyDown"
                         LostFocus="HSVTextBox_LostFocus" />
            </StackPanel>
        </Grid>

        <!-- ===== 按钮 ===== -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ColorWheel_Cancel]}" MinWidth="96" Margin="0,0,8,0"
                    Click="Cancel_Click" />
            <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ColorWheel_OK]}" MinWidth="96"
                    Click="Ok_Click"
                    Style="{StaticResource AccentButton}" />
        </StackPanel>
    </Grid>
</Window>
