      { "value": "invertAlpha", "label": { "zh-Hans": "反转 Alpha", "en": "Invert Alpha" } },
      { "value": "premultiply", "label": { "zh-Hans": "预乘", "en": "Premultiply" } },
      { "value": "unpremultiply", "label": { "zh-Hans": "反预乘", "en": "Unpremultiply" } }
