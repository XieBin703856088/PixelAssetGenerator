  "script": {
    "language": "csharp",
    "code": "{\n// Cache node: pass-through the input image (runtime cache management is handled by the evaluator)\nvar src = inputs[0];\nif (src != null) return src;\nreturn new PixelBuffer(context.TileSize, context.TileSize);\n}"
