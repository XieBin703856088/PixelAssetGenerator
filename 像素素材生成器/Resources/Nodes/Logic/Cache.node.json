{
  "formatVersion": 2,
  "processorType": "Cache",
  "identity": {
    "typeName": "Cache",
    "displayName": {
      "zh-Hans": "缓存",
      "en": "Cache"
    },
    "category": "Logic",
    "description": {
      "zh-Hans": "直通节点，根据缓存键字符串缓存输入图像。当expireFrames为0且缓存中存在该键时，返回缓存副本。当expireFrames不为0时，忽略缓存并直接直通输入。",
      "en": "Pass-through node that caches the input image keyed by a cache key string. When expireFrames is 0 and the key exists in cache, returns the cached copy. When expireFrames is non-zero, ignores cache and passes through the input directly."
    },
    "tags": [],
    "author": "BuiltIn",
    "version": "1.0"
  },
  "ports": {
    "inputs": [
      {
        "name": {
