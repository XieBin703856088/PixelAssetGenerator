<Window x:Class="PixelAssetGenerator.ShapeDrawingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:PixelAssetGenerator.Services.Localization"
        xmlns:local="clr-namespace:PixelAssetGenerator"
        Title="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Title]}" Width="980" Height="760" MinWidth="900" MinHeight="680"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" WindowStyle="SingleBorderWindow"
        Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" FontFamily="{DynamicResource AppFontFamily}"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <!-- Merge shared dark theme resources so this dialog matches the main app theme -->
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />

            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}" />

            <Style TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}" />

            <!-- ListBox dark theme -->
            <Style TargetType="ListBox">
                <Setter Property="Background" Value="{DynamicResource PanelBackground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                <Setter Property="Padding" Value="2" />
            </Style>
            <Style TargetType="ListBoxItem">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="Margin" Value="0,1" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Accent}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentHover}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ContextMenu dark theme -->
            <Style TargetType="ContextMenu">
                <Setter Property="Background" Value="{DynamicResource PanelBackground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                <Setter Property="MinWidth" Value="190" />
                <Setter Property="Padding" Value="5" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="9"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel IsItemsHost="True" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- MenuItem dark theme (used inside the ContextMenu) -->
            <Style TargetType="MenuItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                <Setter Property="Padding" Value="10,7" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0"
                                    CornerRadius="7"
                                    Margin="0,1"
                                    Padding="{TemplateBinding Padding}">
                                <DockPanel>
                                    <!-- Checkmark glyph — always reserves space so text aligns -->
                                    <TextBlock x:Name="CheckGlyph"
                                               DockPanel.Dock="Left"
                                               Text="✔"
                                               FontSize="12"
                                               Width="18"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource Accent}"
                                               Visibility="Hidden" />
                                    <ContentPresenter ContentSource="Header"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True" />
                                </DockPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                                </Trigger>
                                <!-- Only highlight enabled items on hover -->
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsMouseOver" Value="True" />
                                        <Condition Property="IsEnabled" Value="True" />
                                    </MultiTrigger.Conditions>
                                    <MultiTrigger.Setters>
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentHover}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
                                        <Setter TargetName="CheckGlyph" Property="Foreground" Value="{DynamicResource AccentForeground}" />
                                    </MultiTrigger.Setters>
                                </MultiTrigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentPressed}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
                                    <Setter Property="Opacity" Value="0.75" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Separator dark theme (thin rule between menu groups) -->
            <Style TargetType="Separator">
                <Setter Property="Background" Value="{DynamicResource ControlBorder}" />
                <Setter Property="Margin" Value="6,3" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Separator">
                            <Border Height="1"
                                    Background="{TemplateBinding Background}"
                                    Margin="{TemplateBinding Margin}" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Single compact toolbar row -->
            <Border Grid.Row="0"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1" CornerRadius="10" Padding="8,7">
                <DockPanel LastChildFill="True">

                    <!-- Right: Clear -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Rectangle Width="1" Fill="{DynamicResource ControlBorder}" Margin="6,4" VerticalAlignment="Stretch" />
                        <Button x:Name="ClearButton" Width="30" Height="28" Padding="0"
                                Click="Clear_Click" ToolTip="{Binding ClearCanvasToolTip, Source={x:Static local:SettingsService.Hints}}">
                            <TextBlock Text="🗑" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Button>
                    </StackPanel>

                    <!-- Left: Mode group + Color swatch -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <!-- Grouped mode toggle buttons -->
                        <Border BorderBrush="{DynamicResource ControlBorder}" BorderThickness="1" CornerRadius="4">
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton x:Name="PencilModeButton" Width="32" Height="26" IsChecked="True"
                                              Padding="0" BorderThickness="0"
                                              Click="PencilModeButton_Click"
                                              ToolTip="{Binding PencilModeToolTip, Source={x:Static local:SettingsService.Hints}}">
                                    <TextBlock Text="✏" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </ToggleButton>
                                <Rectangle Width="1" Fill="{DynamicResource ControlBorder}" Margin="0,4" />
                                <ToggleButton x:Name="PathModeButton" Width="32" Height="26"
                                              Padding="0" BorderThickness="0"
                                              Click="PathModeButton_Click"
                                              ToolTip="{Binding PathModeToolTip, Source={x:Static local:SettingsService.Hints}}">
                                    <Viewbox Width="14" Height="14">
                                        <Path Stroke="{DynamicResource PrimaryText}" StrokeThickness="1.8"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Data="M2,12 C2,12 5,2 8,8 C11,14 14,4 14,4" Fill="Transparent" />
                                    </Viewbox>
                                </ToggleButton>
                                <Rectangle Width="1" Fill="{DynamicResource ControlBorder}" Margin="0,4" />
                                <ToggleButton x:Name="MoveModeButton" Width="32" Height="26"
                                              Padding="0" BorderThickness="0"
                                              Click="MoveModeButton_Click"
                                              ToolTip="{Binding MoveModeToolTip, Source={x:Static local:SettingsService.Hints}}">
                                    <Viewbox Width="14" Height="14">
                                        <Path Stroke="{DynamicResource PrimaryText}" StrokeThickness="1.6"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                              Data="M1,1 L6,1 L6,6 L1,6 Z M2,8 L14,8 M8,2 L14,8 L8,14" Fill="Transparent" />
                                    </Viewbox>
                                </ToggleButton>
                                <Rectangle Width="1" Fill="{DynamicResource ControlBorder}" Margin="0,4" />
                                <ToggleButton x:Name="ShapeModeButton" Width="32" Height="26"
                                              Padding="0" BorderThickness="0"
                                              Click="ShapeModeButton_Click"
                                              PreviewMouseLeftButtonDown="ShapeModeButton_PreviewMouseDown"
                                              PreviewMouseLeftButtonUp="ShapeModeButton_PreviewMouseUp"
                                              ToolTip="{Binding ShapeModeToolTip, Source={x:Static local:SettingsService.Hints}}">
                                    <Grid>
                                        <TextBlock x:Name="ShapeModeIcon" Text="⬢" FontSize="12"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   Margin="0,0,4,5" />
                                        <!-- Corner-triangle indicator: sits entirely in the bottom-right
                                             corner without overlapping the main icon, signals long-press -->
                                        <Path Data="M 0,6 L 6,6 L 6,0 Z"
                                              Fill="{DynamicResource Accent}"
                                              HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                              Margin="0,0,2,2"
                                              IsHitTestVisible="False" />
                                    </Grid>
                                </ToggleButton>
                            </StackPanel>
                        </Border>

                        <!-- Color swatch button -->
                        <Button x:Name="ColorPickerButton" Width="32" Height="28" Margin="8,0,0,0"
                                Padding="4" Click="ColorPickerButton_Click"
                                ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_ColorPicker]}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border x:Name="ColorPickerSwatch"
                                        Width="14" Height="14" CornerRadius="2"
                                        Background="White"
                                        BorderBrush="{DynamicResource ControlBorder}"
                                        BorderThickness="1" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Center: context-sensitive tool options -->
                    <Grid VerticalAlignment="Center" Margin="4,0">

                        <!-- Pencil context -->
                        <StackPanel x:Name="PencilToolbar" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Size]}" VerticalAlignment="Center" FontSize="10"
                                       Foreground="{DynamicResource MutedText}" Margin="0,0,6,0" />
                            <Slider x:Name="PencilSizeSlider" Width="140" Minimum="1" Maximum="80" Value="1"
                                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                    ToolTip="{Binding BrushSizeToolTip, Source={x:Static local:SettingsService.Hints}}" />
                            <TextBlock x:Name="PencilSizeText" Text="1" VerticalAlignment="Center"
                                       Margin="6,0,0,0" Width="18" TextAlignment="Center" FontSize="10" />
                            <Rectangle Width="1" Fill="{DynamicResource ControlBorder}" Margin="8,4" VerticalAlignment="Stretch" />
                            <ToggleButton x:Name="EraserToggle" Width="30" Height="28" Padding="0"
                                          ToolTip="{Binding EraserToolTip, Source={x:Static local:SettingsService.Hints}}">
                                <Viewbox Width="14" Height="14">
                                    <Path Stroke="{DynamicResource PrimaryText}" StrokeThickness="1.6"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M2,12 L6,4 L12,4 L8,12 Z M1,12 L13,12" Fill="Transparent" />
                                </Viewbox>
                            </ToggleButton>
                        </StackPanel>

                        <!-- Path context -->
                        <StackPanel x:Name="PathToolbar" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_LineWidth]}" VerticalAlignment="Center" FontSize="10"
                                       Foreground="{DynamicResource MutedText}" Margin="0,0,6,0" />
                            <Slider x:Name="PathWidthSlider" Width="120" Minimum="1" Maximum="8" Value="1"
                                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                    ToolTip="{Binding BrushSizeToolTip, Source={x:Static local:SettingsService.Hints}}" />
                            <TextBlock x:Name="PathWidthText" Text="1" VerticalAlignment="Center"
                                       Margin="6,0,0,0" Width="18" TextAlignment="Center" FontSize="10" />
                            <Rectangle Width="1" Fill="{DynamicResource ControlBorder}" Margin="8,4" VerticalAlignment="Stretch" />
                            <Button Width="30" Height="28" Padding="0"
                                    Click="FinishCurrentPath_Click"
                                    ToolTip="{Binding FinishPathToolTip, Source={x:Static local:SettingsService.Hints}}">
                                <Viewbox Width="14" Height="14">
                                    <Path Stroke="{DynamicResource PrimaryText}" StrokeThickness="1.8"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M2,7 L6,11 L13,3" Fill="Transparent" />
                                </Viewbox>
                            </Button>
                            <ToggleButton x:Name="PathFillToggle" Width="30" Height="28" Padding="0" Margin="4,0,0,0"
                                          ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_PathFillToggle]}">
                                <Viewbox Width="14" Height="14">
                                    <Grid>
                                        <Path Data="M2,2 L14,2 L14,14 L2,14 Z"
                                              Fill="{DynamicResource MutedText}" Stroke="Transparent" />
                                        <Path Data="M2,2 L14,2 L14,14 L2,14 Z"
                                              Fill="Transparent"
                                              Stroke="{DynamicResource PrimaryText}" StrokeThickness="1.4" />
                                    </Grid>
                                </Viewbox>
                            </ToggleButton>
                        </StackPanel>

                        <!-- Move mode context: brief hint -->
                        <StackPanel x:Name="MoveToolbar" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_MoveInstructions]}"
                                       VerticalAlignment="Center" FontSize="10"
                                       Foreground="{DynamicResource MutedText}" />
                        </StackPanel>

                        <!-- Shape stamp context -->
                        <StackPanel x:Name="ShapeToolbar" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed">
                            <TextBlock x:Name="ShapeTypeLabel" Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_ShapeType_Default]}" VerticalAlignment="Center" FontSize="10"
                                       Foreground="{DynamicResource MutedText}" Margin="0,0,8,0" MinWidth="36" />
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Size]}" VerticalAlignment="Center" FontSize="10"
                                       Foreground="{DynamicResource MutedText}" Margin="0,0,6,0" />
                            <Slider x:Name="ShapeSizeSlider" Width="120" Minimum="1" Maximum="32" Value="4"
                                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                    ToolTip="{Binding BrushSizeToolTip, Source={x:Static local:SettingsService.Hints}}" />
                            <TextBlock x:Name="ShapeSizeText" Text="4" VerticalAlignment="Center"
                                       Margin="6,0,0,0" Width="18" TextAlignment="Center" FontSize="10" />
                        </StackPanel>

                    </Grid>
                </DockPanel>
            </Border>

            <!-- Instruction / status row -->
            <TextBlock Grid.Row="1"
                       x:Name="InstructionText"
                       Margin="2,5,0,0"
                       VerticalAlignment="Center"
                       FontSize="10"
                       Opacity="0.7"
                       Foreground="{DynamicResource MutedText}" />
        </Grid>

        <!-- Canvas area -->
        <Border Grid.Row="1" Grid.Column="0" BorderBrush="{DynamicResource ControlBorder}" BorderThickness="1" Background="{DynamicResource WindowBackground}" HorizontalAlignment="Center" VerticalAlignment="Top">
            <Canvas x:Name="DrawCanvas" Width="512" Height="512" ClipToBounds="True"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                    MouseRightButtonDown="Canvas_MouseRightButtonDown"
                    MouseMove="Canvas_MouseMove"
                    MouseLeave="Canvas_MouseLeave"
                    Background="Transparent" />
        </Border>

        <!-- Footer: info and actions -->
        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Vertices]}" VerticalAlignment="Center" Opacity="0.8" />
                <TextBlock x:Name="VertexCountText" Text="0" Margin="6,0,12,0" />
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Paths]}" VerticalAlignment="Center" Opacity="0.8" />
                <TextBlock x:Name="PathCountText" Text="0" Margin="6,0,12,0" />
            </StackPanel>
            <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Cancel]}" MinWidth="96" Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_OK]}" MinWidth="96" Click="OK_Click" Style="{StaticResource AccentButton}" />
        </StackPanel>

        <!-- ================================================================ -->
        <!-- Layer list sidebar (Column 1) - always visible                  -->
        <!-- ================================================================ -->
        <Border x:Name="PathListSidebar"
                Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                Width="240" Margin="12,0,0,0"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource ControlBorder}"
                BorderThickness="1" CornerRadius="6">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <DockPanel Grid.Row="0" Margin="0,0,0,6" LastChildFill="False">
                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_LayerList]}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right" Content="－" Width="22" Height="22" FontSize="13" Padding="0"
                            Click="DeleteLayer_Click" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_DeleteLayer]}" />
                    <Button DockPanel.Dock="Right" Content="＋" Width="22" Height="22" FontSize="13" Padding="0"
                            Margin="0,0,4,0" Click="AddLayer_Click" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_AddPencilLayer]}" />
                    <Button DockPanel.Dock="Right" Content="↓" Width="22" Height="22" FontSize="13" Padding="0"
                            Margin="0,0,4,0" Click="MoveLayerDown_Click" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_MoveLayerDown]}" />
                    <Button DockPanel.Dock="Right" Content="↑" Width="22" Height="22" FontSize="13" Padding="0"
                            Margin="0,0,4,0" Click="MoveLayerUp_Click" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_MoveLayerUp]}" />
                </DockPanel>

                <!-- Path list -->
                <ListBox Grid.Row="1"
                         x:Name="PathListBox"
                         SelectionChanged="PathListBox_SelectionChanged"
                         MinHeight="120"
                         MaxHeight="480">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,5,0"
                                           Opacity="{Binding NameOpacity}" />
                                <!-- Column 1: display mode (StackPanel) or rename mode (TextBox) -->
                                <Grid Grid.Column="1" Opacity="{Binding NameOpacity}">
                                    <StackPanel Visibility="{Binding IsNotRenaming, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="11" />
                                        <TextBlock Text="{Binding Info}" FontSize="10" Opacity="0.65" />
                                    </StackPanel>
                                    <TextBox Text="{Binding EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsRenaming, Converter={StaticResource BoolToVis}}"
                                             FontSize="11" FontWeight="SemiBold"
                                             Background="Transparent"
                                             BorderThickness="0,0,0,1"
                                             BorderBrush="{DynamicResource Accent}"
                                             Foreground="{DynamicResource PrimaryText}"
                                             Padding="0" VerticalAlignment="Center"
                                             LostFocus="RenameTextBox_LostFocus"
                                             KeyDown="RenameTextBox_KeyDown" />
                                </Grid>
                                <!-- Visibility toggle button: 👁 = visible, ○ = hidden -->
                                <Button Grid.Column="2"
                                        Content="{Binding VisibilityIcon}"
                                        Tag="{Binding}"
                                        Width="20" Height="20" FontSize="11" Padding="0"
                                        VerticalAlignment="Center" Margin="4,0,0,0"
                                        ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_ToggleVisibility]}"
                                        Click="ToggleLayerVisibility_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderThickness="0" CornerRadius="3" Padding="1">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource AccentHover}" />
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource AccentPressed}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Stable properties zone: MinHeight reserves fixed space so the ListBox above never jumps -->
                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource ControlBorder}"
                        BorderThickness="0,1,0,0"
                        Margin="0,6,0,0"
                        Padding="0,8,0,0"
                        MinHeight="108">
                    <Grid>
                        <!-- Placeholder: visible when no path/shape layer is being edited -->
                        <TextBlock x:Name="PropertiesPlaceholder"
                                   Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_SelectLayerHint]}"
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Foreground="{DynamicResource MutedText}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />

                        <!-- Shape layer properties: shown when a shape layer is selected -->
                        <StackPanel x:Name="ShapeLayerPanel" Visibility="Collapsed" VerticalAlignment="Top">
                            <Button x:Name="ShapeLayerColorButton"
                                    Margin="0,0,0,6" MinHeight="36" FontSize="12"
                                    Click="ShapeLayerColor_Click"
                                    ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_RecolorShape]}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border x:Name="ShapeLayerColorSwatch"
                                            Width="12" Height="12" CornerRadius="2"
                                            Margin="0,0,5,0"
                                            Background="White"
                                            BorderBrush="{DynamicResource ControlBorder}"
                                            BorderThickness="1" />
                                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_ModifyColor]}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Edit controls: shown when a path is being edited -->
                        <StackPanel x:Name="EditActionsPanel" Visibility="Collapsed" VerticalAlignment="Top">
                            <!-- Action row: finish editing + fill toggle side by side -->
                            <UniformGrid Columns="2" Margin="0,0,0,4">
                                <Button x:Name="FinishEditButton"
                                        Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_FinishEdit]}"
                                        Margin="0,0,3,0" MinHeight="36" FontSize="12"
                                        Click="FinishEdit_Click"
                                        Visibility="Collapsed"
                                        ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_FinishEditPath]}" />
                                <ToggleButton x:Name="EditPathFillButton"
                                              Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_PathFill]}"
                                              Margin="3,0,0,0" MinHeight="36" FontSize="12"
                                              Click="ToggleEditPathFill_Click"
                                              Visibility="Collapsed"
                                              ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_TogglePathFill]}" />
                            </UniformGrid>

                            <!-- Layer color row: modify the color of the editing path -->
                            <Button x:Name="EditLayerColorButton"
                                    Margin="0,0,0,6" MinHeight="36" FontSize="12"
                                    Click="EditLayerColor_Click"
                                    Visibility="Collapsed"
                                    ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_ModifyLayerColor]}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border x:Name="EditLayerColorSwatch"
                                            Width="12" Height="12" CornerRadius="2"
                                            Margin="0,0,5,0"
                                            Background="White"
                                            BorderBrush="{DynamicResource ControlBorder}"
                                            BorderThickness="1" />
                                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_ModifyColor]}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <!-- Anchor-type edit panel: visible when an anchor is selected -->
                            <Border x:Name="AnchorEditPanel"
                                    BorderBrush="{DynamicResource ControlBorder}"
                                    BorderThickness="0,1,0,0"
                                    Margin="0,4,0,0"
                                    Padding="0,8,0,0"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_AnchorType]}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6" />
                                    <UniformGrid Columns="4">
                                        <ToggleButton x:Name="CornerTypeButton"
                                                      Content="□"
                                                      Margin="0,0,2,0" Height="26" FontSize="14"
                                                      Click="SetAnchorTypeCorner_Click"
                                                      ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Corner]}" />
                                        <ToggleButton x:Name="BezierTypeButton"
                                                      Content="◎"
                                                      Margin="1,0,1,0" Height="26" FontSize="14"
                                                      Click="SetAnchorTypeBezier_Click"
                                                      ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Bezier]}" />
                                        <ToggleButton x:Name="BezierCornerTypeButton"
                                                      Content="◈"
                                                      Margin="1,0,1,0" Height="26" FontSize="14"
                                                      Click="SetAnchorTypeBezierCorner_Click"
                                                      ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_BezierCorner]}" />
                                        <Button Content="✕"
                                                Margin="2,0,0,0" Height="26" FontSize="14"
                                                Click="DeleteSelectedAnchor_Click"
                                                ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_DeleteAnchor]}" />
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
            <!-- ================================================================ -->
            <!-- Shape picker popup — opened on long-press of ShapeModeButton   -->
            <!-- ================================================================ -->
            <Popup x:Name="ShapePickerPopup"
                   Grid.Row="0" Grid.Column="0"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource ControlBorder}"
                        BorderThickness="1" CornerRadius="8" Padding="6">
                    <UniformGrid Columns="4" Rows="2">
                        <Button Tag="Circle"   Width="52" Height="52" Margin="2" Click="ShapePicker_Click" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Circle]}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="●" FontSize="18" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Circle]}" FontSize="9" HorizontalAlignment="Center" Opacity="0.7" />
                            </StackPanel>
                        </Button>
                        <Button Tag="Square"   Width="52" Height="52" Margin="2" Click="ShapePicker_Click" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Square]}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="■" FontSize="18" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Square]}" FontSize="9" HorizontalAlignment="Center" Opacity="0.7" />
                            </StackPanel>
                        </Button>
                        <Button Tag="Diamond"  Width="52" Height="52" Margin="2" Click="ShapePicker_Click" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Diamond]}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="◆" FontSize="18" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Diamond]}" FontSize="9" HorizontalAlignment="Center" Opacity="0.7" />
                            </StackPanel>
                        </Button>
                        <Button Tag="Triangle" Width="52" Height="52" Margin="2" Click="ShapePicker_Click" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Triangle]}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="▲" FontSize="18" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Triangle]}" FontSize="9" HorizontalAlignment="Center" Opacity="0.7" />
                            </StackPanel>
                        </Button>
                        <Button Tag="Ring"     Width="52" Height="52" Margin="2" Click="ShapePicker_Click" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Ring]}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="○" FontSize="18" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Ring]}" FontSize="9" HorizontalAlignment="Center" Opacity="0.7" />
                            </StackPanel>
                        </Button>
                        <Button Tag="Star"     Width="52" Height="52" Margin="2" Click="ShapePicker_Click" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Star]}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="★" FontSize="18" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Star]}" FontSize="9" HorizontalAlignment="Center" Opacity="0.7" />
                            </StackPanel>
                        </Button>
                        <Button Tag="Cross"    Width="52" Height="52" Margin="2" Click="ShapePicker_Click" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Cross]}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="✚" FontSize="18" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Cross]}" FontSize="9" HorizontalAlignment="Center" Opacity="0.7" />
                            </StackPanel>
                        </Button>
                        <Button Tag="Hexagon"  Width="52" Height="52" Margin="2" Click="ShapePicker_Click" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Hexagon]}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="⬢" FontSize="18" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[ShapeDraw_Hexagon]}" FontSize="9" HorizontalAlignment="Center" Opacity="0.7" />
                            </StackPanel>
                        </Button>
                    </UniformGrid>
                </Border>
            </Popup>

        </Grid>
    </Window>
