                                                            <TextBox Grid.Column="1" Style="{StaticResource RangeInputTextBox}" Text="{Binding ActiveTileProperties.RoadCenterLineRoughness, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" />
                                                        </Grid>

                                                    </StackPanel>
                                                </Expander>
                                                <!-- ===== 建筑属性面板 ===== -->
                                                <Expander IsExpanded="True">
                                                    <Expander.Header>
                                                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_BuildingPreview]}" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold" />
                                                    </Expander.Header>
                                                    <Expander.Style>
                                                        <Style TargetType="Expander">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedNode.Category, RelativeSource={RelativeSource AncestorType=Window}}" Value="建筑">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Expander.Style>
                                                    <StackPanel>
                                                        <!-- 多图块预览网格 -->
                                                        <Border Background="{DynamicResource WindowBackground}" CornerRadius="{StaticResource ControlCornerRadius}" Padding="4" Margin="0,0,0,8">
                                                            <ItemsControl ItemsSource="{Binding BuildingTilePreviewCells, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                HorizontalAlignment="Center">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Width="20" Height="20" Margin="1" CornerRadius="2" BorderBrush="{DynamicResource ControlBorder}" BorderThickness="1">
                                                                            <Rectangle Fill="{Binding Color}" />
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Border>
                                                    </StackPanel>
                                                </Expander>
                                                <!-- ===== 变体浏览器 ===== -->
                                                <Expander IsExpanded="True">
                                                    <Expander.Header>
                                                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_VariationPreview]}" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold" />
                                                    </Expander.Header>
                                                    <Expander.Style>
                                                        <Style TargetType="Expander">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedNode.Title, RelativeSource={RelativeSource AncestorType=Window}}" Value="变体">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Expander.Style>
                                                    <StackPanel>
                                                        <ItemsControl ItemsSource="{Binding VariationPreviews, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            HorizontalAlignment="Center">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Width="48" Height="48" Margin="2"
                                                                        CornerRadius="4"
                                                                        BorderBrush="{DynamicResource ControlBorder}"
                                                                        BorderThickness="1"
                                                                        Cursor="Hand"
                                                                        Tag="{Binding Seed}"
                                                                        PreviewMouseLeftButtonDown="VariationPreview_Click">
                                                                        <Rectangle Fill="{Binding Preview}" Stretch="UniformToFill" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Expander>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ContentControl.ContentTemplate>
                                </ContentControl>

                                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_SelectNodeToEdit]}" 
                                           HorizontalAlignment="Center" 
                                           Foreground="{DynamicResource MutedText}" 
                                           Margin="0,36,0,0" 
                                           Visibility="Collapsed">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNode, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- 分割条2 -->
                <GridSplitter Grid.Row="3"
                              Height="2"
                              ResizeDirection="Rows"
                              HorizontalAlignment="Stretch"
                              Background="{DynamicResource PanelBorder}"
                              ShowsPreview="True" />

                <!-- 节点列表面板 -->
                <Border Grid.Row="4"
                        Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}"
                        MinHeight="0"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Node]}" Style="{StaticResource SectionTitle}" />
                        </StackPanel>
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Nodes}"
                                 SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                                 ItemContainerStyle="{StaticResource NodeListItemStyle}"
                                 Background="{DynamicResource PanelBackgroundAlt}"
                                 BorderBrush="{DynamicResource ControlBorder}"
                                 BorderThickness="1"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <Border Width="28"
                                                Height="28"
                                                Background="{Binding PreviewBrush}"
                                                BorderBrush="{DynamicResource ControlBorder}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Margin="0,0,8,0" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="11" />
                                            <TextBlock Text="{Binding Id}" Foreground="{DynamicResource MutedText}" FontSize="10" />
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===== AI 面板分割条 ===== -->
            <GridSplitter x:Name="InspectorDockSplitter"
                          Grid.Column="5"
                          Style="{StaticResource VerticalDockSplitterStyle}" />

            <!-- ===== AI 助手面板（仿 Claude 桌面版） ===== -->
            <Border Grid.Column="6"
                    x:Name="AiMainPanel"
                    Style="{StaticResource WorkspaceCardStyle}"
                    ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- 顶部标题栏 -->
                    <RowDefinition Height="*" />
                    <!-- 内容区：历史侧边栏+消息列表 -->
                    <RowDefinition Height="Auto" />
                    <!-- 底部输入区 -->
                </Grid.RowDefinitions>

                <!-- ── 顶部标题栏 ── -->
                <Border Grid.Row="0"
                        Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 左：历史侧边栏展开按钮 -->
                        <Button x:Name="AiHistoryToggleBtn"
                                Grid.Column="0"
                                Content="☰"
                                FontSize="14"
                                Width="30" Height="30"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource MutedText}"
                                Cursor="Hand"
                                ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_ChatHistory]}"
                                Click="AiHistoryToggle_Click" />

                        <!-- 中：当前对话标题 + 状态 -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                            <TextBlock x:Name="AiSessionTitle"
                                       Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_NewChat]}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryText}"
                                       TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="AiConnectionDot"
                                         Width="6" Height="6"
                                         Fill="#4CAF50"
                                         VerticalAlignment="Center"
                                         Margin="0,0,4,0" />
                                <TextBlock x:Name="AiStatusText"
                                           Text="{Binding AiChat.StatusText}"
                                           FontSize="10"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="AiLiveStatusText"
                                           Text="{Binding AiChat.LiveStatusText}"
                                           FontSize="10"
                                           Foreground="{DynamicResource Accent}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center" />
                                <TextBlock x:Name="AiThinkingDots"
                                           FontSize="10"
                                           Foreground="{DynamicResource Accent}"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed" />
                            </StackPanel>
                        </StackPanel>

                        <!-- 右：新建对话按钮 + 模式选择 -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <ComboBox x:Name="AiPermissionCombo"
                                      Width="111"
                                      Margin="0,0,6,0"
                                      FontSize="11"
                                      SelectedIndex="2"
                                      ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[AI_SelectMode]}">
                                <ComboBoxItem Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Plan]}" Tag="Plan" />
                                <ComboBoxItem Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_ExecutionMode]}" Tag="Execute" />
                                <ComboBoxItem Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_SkipPermissions]}" Tag="SkipPermissions" />
                            </ComboBox>
                            <Button x:Name="AiNewChatBtn"
                                    Content="＋"
                                    FontSize="16"
                                    Width="30" Height="30"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{DynamicResource Accent}"
                                    Cursor="Hand"
                                    ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_NewChat2]}"
                                    Click="AiNewChat_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── 内容区（历史侧边栏 + 消息列表 + 计划面板） ── -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <!-- 历史侧边栏（可折叠） -->
                        <ColumnDefinition x:Name="AiHistorySidebarCol" Width="0" MinWidth="0" />
                        <!-- 消息 + 计划 -->
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 历史侧边栏 -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource PanelBackgroundAlt}"
                            BorderBrush="{DynamicResource PanelBorder}"
                            BorderThickness="0,0,1,0"
                            ClipToBounds="True">
                        <DockPanel>
                            <Border DockPanel.Dock="Top"
                                    Padding="12,10,12,8"
                                    BorderBrush="{DynamicResource PanelBorder}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_ChatHistory]}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedText}"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Content="✕"
                                            FontSize="11"
                                            Width="22" Height="22"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource MutedText}"
                                            Cursor="Hand"
                                            Click="AiHistoryToggle_Click" />
                                </Grid>
                            </Border>
                            <controls:AiSessionListControl
                                x:Name="AiSessionList"
                                DockPanel.Dock="Top" />
                        </DockPanel>
                    </Border>

                    <!-- 右侧：计划面板（可折叠）+ 消息列表 -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <!-- 计划面板 -->
                            <RowDefinition Height="*" />
                            <!-- 消息列表 -->
                        </Grid.RowDefinitions>

                        <!-- 计划面板（折叠/展开） -->
                        <Border x:Name="AiPlanPanel"
                                Grid.Row="0"
                                Background="{DynamicResource PanelBackgroundAlt}"
                                BorderBrush="{DynamicResource PanelBorder}"
                                BorderThickness="0,0,0,1"
                                Visibility="Collapsed">
                            <Grid Margin="10,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <!-- 计划标题行 -->
                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="📋 "
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="AiPlanTitleText"
                                               Grid.Column="1"
                                               Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_TaskPlan]}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Accent}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <Button x:Name="AiOpenPlanFileBtn"
                                            Grid.Column="2"
                                            Content="📂"
                                            FontSize="11"
                                            Padding="4,2"
                                            Margin="4,0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource Accent}"
                                            Cursor="Hand"
                                            ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_OpenPlanFile]}"
                                            Click="AiOpenPlanFile_Click" />
                                    <Button Grid.Column="3"
                                            Content="▲"
                                            FontSize="10"
                                            Width="22" Height="22"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="{DynamicResource MutedText}"
                                            Cursor="Hand"
                                            ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_CollapsePlanPanel]}"
                                            Click="AiCollapsePlan_Click" />
                                </Grid>
                                <!-- PlanViewer -->
                                <controls:PlanViewer x:Name="AiPlanViewer"
                                                     Grid.Row="1" />
                            </Grid>
                        </Border>

                        <!-- 折叠状态下的计划小条 -->
                        <Border x:Name="AiPlanCollapsedBar"
                                Grid.Row="0"
                                Background="{DynamicResource PanelBackgroundAlt}"
                                BorderBrush="{DynamicResource PanelBorder}"
                                BorderThickness="0,0,0,1"
                                Padding="10,5"
                                Cursor="Hand"
                                Visibility="Collapsed"
                                MouseLeftButtonUp="AiExpandPlan_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋 " FontSize="11" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_ViewTaskPlan]}" FontSize="11" Foreground="{DynamicResource Accent}" VerticalAlignment="Center" />
                                <TextBlock Text=" ▼" FontSize="9" Foreground="{DynamicResource MutedText}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- 消息列表 -->
                        <ScrollViewer x:Name="AiChatScrollViewer"
                                      Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      PanningMode="Both" PanningDeceleration="0.002"
                                      Background="{DynamicResource WindowBackground}"
                                      Padding="0">
                            <!-- 使用 ListBox（VirtualizingStackPanel）+ DataTemplateSelector，
                                 每条消息只实例化对应角色的控件树 -->
                            <ListBox x:Name="AiChatList"
                                     ItemsSource="{Binding AiChat.Messages}"
                                     ItemTemplateSelector="{StaticResource AiMsgSelector}"
                                     Margin="0,8,0,8"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                     VirtualizingStackPanel.IsVirtualizing="True"
                                     VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- ── 底部输入区 ── -->
                <Border Grid.Row="2"
                        Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="0,1,0,0"
                        Padding="10,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <!-- 附件条 -->
                            <RowDefinition Height="Auto" />
                            <!-- 输入框 -->
                            <RowDefinition Height="Auto" />
                            <!-- 工具栏 -->
                        </Grid.RowDefinitions>

                        <!-- 附件 chips -->
                        <ItemsControl x:Name="AiAttachmentList"
                                      Grid.Row="0"
                                      Visibility="Collapsed"
                                      Margin="0,0,0,6">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource ControlBackground}"
                                            CornerRadius="4"
                                            Padding="6,3"
                                            Margin="0,0,4,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding FileName}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource MutedText}"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="1"
                                                    Content="×"
                                                    FontSize="11"
                                                    Padding="3,0"
                                                    Margin="4,0,0,0"
                                                    BorderThickness="0"
                                                    Background="Transparent"
                                                    Foreground="{DynamicResource MutedText}"
                                                    Tag="{Binding}"
                                                    Click="AiRemoveAttachment_Click" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 输入框 + 发送按钮 -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource ControlBackground}"
                                BorderBrush="{DynamicResource PanelBorder}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        x:Name="AiAttachButton"
                                        Width="28" Height="28"
                                        Padding="5"
                                        Margin="0,0,6,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{DynamicResource MutedText}"
                                        Cursor="Hand"
                                        VerticalAlignment="Bottom"
                                        ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_UploadImageOrFile]}"
                                        Click="AiAttachFile_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent"
                                                    Padding="{TemplateBinding Padding}">
                                                <Viewbox>
                                                    <Canvas Width="24" Height="24">
                                                        <!-- 回形针图标 -->
                                                        <Path Fill="{TemplateBinding Foreground}"
                                                              Data="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentHover}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBox x:Name="AiInputBox"
                                         Grid.Column="1"
                                         AcceptsReturn="False"
                                         TextWrapping="Wrap"
                                         MinHeight="20"
                                         MaxHeight="120"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="Transparent"
                                         Foreground="{DynamicResource PrimaryText}"
                                         BorderThickness="0"
                                         FontSize="13"
                                         Padding="0,2"
                                         VerticalAlignment="Center"
                                         CaretBrush="{DynamicResource Accent}"
                                         KeyDown="AiInputBox_KeyDown"
                                         TextChanged="AiInputBox_TextChanged" />
                                <Button Grid.Column="2"
                                        x:Name="AiSendButton"
                                        Height="32"
                                        Padding="14,0"
                                        Margin="6,0,0,0"
                                        IsEnabled="False"
                                        VerticalAlignment="Bottom"
                                        Click="AiSendButton_Click"
                                        Background="{DynamicResource Accent}"
                                        BorderBrush="{DynamicResource Accent}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_SendEnter]}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <TextBlock x:Name="BtnText"
                                                           Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Send]}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentForeground}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}" />
                                                    <Setter TargetName="BtnText" Property="Foreground" Value="{DynamicResource MutedText}" />
                                                    <Setter TargetName="BtnText" Property="Opacity" Value="0.6" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AccentHover}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- 底部工具栏：推理 + 模型切换 + 停止 -->
                        <Grid Grid.Row="2" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Thinking]}"
                                       FontSize="10"
                                       Foreground="{DynamicResource MutedText}"
                                       VerticalAlignment="Center" />
                            <ComboBox x:Name="AiReasoningCombo"
                                      Grid.Column="1"
                                      MinWidth="56"
                                      Width="Auto"
                                      Margin="4,0,0,0"
                                      FontSize="10"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Mode=OneTime, Path=[MW_Close]}" Tag="off" />
                                <ComboBoxItem Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Mode=OneTime, Path=[MW_Lowest]}" Tag="minimal" />
                                <ComboBoxItem Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Mode=OneTime, Path=[MW_Low]}" Tag="low" />
                                <ComboBoxItem Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Mode=OneTime, Path=[MW_Medium]}" Tag="medium" />
                                <ComboBoxItem Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Mode=OneTime, Path=[MW_High]}" Tag="high" />
                                <ComboBoxItem Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Mode=OneTime, Path=[MW_Highest]}" Tag="max" />
                            </ComboBox>
                            <Separator Grid.Column="2"
                                       Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                       Margin="6,0,6,0" />
                            <TextBlock Grid.Column="3"
                                       Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Model]}"
                                       FontSize="10"
                                       Foreground="{DynamicResource MutedText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0" />
                            <ComboBox x:Name="AiModelSwitchCombo"
                                      Grid.Column="4"
                                      MinWidth="80"
                                      MaxWidth="200"
                                      FontSize="10"
                                      Margin="0,0,6,0"
                                      Background="{DynamicResource ControlBackground}"
                                      Foreground="{DynamicResource PrimaryText}"
                                      BorderBrush="{DynamicResource ControlBorder}"
                                      SelectionChanged="AiModelSwitchCombo_SelectionChanged"
                                      ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_SwitchModelHint]}" />
                            <Button x:Name="AiStopButton"
                                    Grid.Column="5"
                                    Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Stop]}"
                                    FontSize="10"
                                    Padding="8,3"
                                    Background="Transparent"
                                    BorderBrush="#3A2020"
                                    BorderThickness="1"
                                    Foreground="#E05050"
                                    Cursor="Hand"
                                    Visibility="Collapsed"
                                    Click="AiStopButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2D1B1B" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
            </Border>
        </Grid>

        <!-- ========== 底部状态栏 ========== -->
        <Border Grid.Row="2"
                Margin="8,0,8,8"
                Padding="12,7"
                Style="{StaticResource WorkspaceCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse Width="6" Height="6"
                             Fill="{DynamicResource SuccessBrush}"
                             Margin="0,0,7,0"
                             VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusText" Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Ready]}" VerticalAlignment="Center" />
                    <ProgressBar x:Name="EvalProgressBar" Width="80" Height="8" Margin="8,0,0,0"
                                 IsIndeterminate="True" Visibility="Collapsed" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="拖动画布 · 滚轮缩放 · Delete 删除"
                           Foreground="{DynamicResource MutedText}"
                           FontSize="10"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="2"
                           Text="PIXEL GRAPH  ·  LIVE PREVIEW"
                           Foreground="{DynamicResource MutedText}"
                           FontSize="9"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
