<Window x:Class="PixelAssetGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PixelAssetGenerator"
        xmlns:controls="clr-namespace:PixelAssetGenerator.Controls"
        xmlns:media="clr-namespace:System.Windows.Media;assembly=PresentationCore"
        xmlns:loc="clr-namespace:PixelAssetGenerator.Services.Localization"
        xmlns:converters="clr-namespace:PixelAssetGenerator.Converters"
        mc:Ignorable="d"
        Title="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[AppTitle]}"
        Height="760" Width="1360" MinWidth="1080" MinHeight="680" WindowState="Maximized"
        Background="{DynamicResource WindowBackground}" 
        Foreground="{DynamicResource PrimaryText}" 
        FontFamily="{DynamicResource AppFontFamily}"
        Loaded="MainWindow_Loaded" 
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <local:ParameterMaxConverter x:Key="ParamMaxConverter" />
        <local:InverseScaleConverter x:Key="InverseScaleConverter" />
        <converters:SliderFillWidthConverter x:Key="SliderFillWidthConverter" />
        <!-- Color converters -->
        <local:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <local:ColorToHexConverter x:Key="ColorToHexConverter" />
        <local:NodeDescriptionConverter x:Key="NodeDescriptionConverter" />
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <local:ThumbnailSizeConverter x:Key="ThumbnailSizeConverter" />

        <!-- 网格笔刷 -->
        <!--
            为了在屏幕上呈现比一个物理像素更细的线条，WPF 的设备像素对齐会把非常小的 Thickness 四舍五入到最近的物理像素，
            导致设置 Thickness="0.1" 仍然看起来为 1 像素。
            采用的技巧是：在更大的瓷砖 (Viewport) 上以 1px 绘制线条，然后对整个 Brush 做缩放（ScaleTransform）——
            缩放后线条视觉上会小于 1px（例如这里缩放到 0.25，相当于 1 * 0.25 = 0.25px）。
            同时通过较低的 alpha 值保持细线柔和效果。
        -->
        <DrawingBrush x:Key="FineGridBrush" TileMode="Tile" Viewport="0,0,64,64" ViewportUnits="Absolute" Stretch="None">
            <!-- 将 Brush 缩放 0.25 倍，使得在 64x64 上绘制的 1px 线最终显示为 0.25px 的视觉效果 -->
            <DrawingBrush.Transform>
                <ScaleTransform ScaleX="0.25" ScaleY="0.25" />
            </DrawingBrush.Transform>
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="64,0" />
                            <LineGeometry StartPoint="0,0" EndPoint="0,64" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Pen>
                        <!-- 使用 1px 的矢量线并降低 alpha，使缩放后线条看起来非常细且柔和 -->
                        <Pen Brush="#0AFFFFFF" Thickness="1" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- Preview pixel grid brush: scaled inversely to the preview transform so lines stay thin when zoomed -->
        <DrawingBrush x:Key="PreviewPixelGridBrush" TileMode="Tile" Viewport="0,0,64,64" ViewportUnits="Absolute" Stretch="None">
            <!-- 改进：先将瓷砖上的 1px 线缩小到更细（0.125），再应用预览缩放的逆缩放，从而在放大/缩小时保持视觉粗细不变且线更细 -->
            <DrawingBrush.Transform>
                <TransformGroup>
                    <!-- 缩小到更细的子像素宽度 (0.125 -> 1 * 0.125 = 0.125px) -->
                    <ScaleTransform ScaleX="0.125" ScaleY="0.125" />
                    <!-- 逆向抵消预览缩放，使得网格线在缩放时看起来粗细不变 -->
                    <ScaleTransform ScaleX="{Binding ScaleX, ElementName=PreviewScale, Converter={StaticResource InverseScaleConverter}}" ScaleY="{Binding ScaleY, ElementName=PreviewScale, Converter={StaticResource InverseScaleConverter}}" />
                </TransformGroup>
            </DrawingBrush.Transform>
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="64,0" />
                            <LineGeometry StartPoint="0,0" EndPoint="0,64" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Pen>
                        <!-- 降低 alpha 并保留 1px 矢量线，在缩放与逆缩放组合下表现为更细且柔和的网格线 -->
                        <Pen Brush="#20FFFFFF" Thickness="1" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <DrawingBrush x:Key="CoarseGridBrush" TileMode="Tile" Viewport="0,0,256,256" ViewportUnits="Absolute" Stretch="None">
            <!-- 同样的缩放技巧：在更大的瓷砖上用 1px 绘制，然后缩放到 0.25，最终视觉间距仍为 64 -->
            <DrawingBrush.Transform>
                <ScaleTransform ScaleX="0.25" ScaleY="0.25" />
            </DrawingBrush.Transform>
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="256,0" />
                            <LineGeometry StartPoint="0,0" EndPoint="0,256" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#18FFFFFF" Thickness="1" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- 主窗口仅保留行为和布局差异，视觉由 AppResources 统一管理。 -->
        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}" />
        <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="Margin" Value="0,2,0,6" />
        </Style>

        <!-- 次级切换按钮 -->
        <Style x:Key="SecondaryToggleButton"
               TargetType="ToggleButton"
               BasedOn="{StaticResource WorkspaceToggleButton}" />

        <!-- 数字输入框 -->
        <Style x:Key="RangeInputTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="56" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="FontSize" Value="9" />
        </Style>

        <!-- 区域标题 -->
        <Style x:Key="SectionTitle" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <!-- 展开器 -->
        <Style TargetType="Expander">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource ControlCornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <DockPanel>
                                <ToggleButton x:Name="HeaderSite"
                                              DockPanel.Dock="Top"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Content="{TemplateBinding Header}"
                                              FontWeight="SemiBold"
                                              FontSize="13"
                                              Foreground="{DynamicResource PrimaryText}"
                                              HorizontalContentAlignment="Left"
                                              Padding="4,3"
                                              Margin="0,0,0,4"
                                              FocusVisualStyle="{x:Null}"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpandSite"
                                                  ContentSource="Content" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="HeaderSite" Property="Margin" Value="0" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="HeaderSite" Property="Margin" Value="0,0,0,4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 字段标签 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <!-- 文本框 -->
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <!-- 按回车键提交编辑：统一将绑定值推送到源。 -->
            <EventSetter Event="PreviewKeyDown" Handler="TextBox_PreviewKeyDown_Commit" />
        </Style>

        <!-- 组合框 -->
        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}" />
        <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}" />

        <!-- 共享 Slider 模板确保滑块中心与轨道严格对齐；主窗口只保留滚轮行为。 -->
        <Style TargetType="Slider" BasedOn="{StaticResource {x:Type Slider}}">
            <EventSetter Event="PreviewMouseWheel" Handler="Slider_PreviewMouseWheel" />
        </Style>

        <!-- 主题化 ScrollBar，使列表/滚动条与整体配色和谐 -->
        <Style x:Key="ScrollBarRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Make repeat buttons take no layout space so thumb can reach ends -->
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="0" />
            <Setter Property="Width" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <!-- Use min sizes instead of fixed size so thumb can stretch to track ends -->
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                SnapsToDevicePixels="True" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentHover}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentHover}" />
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentPressed}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentPressed}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}" Command="ScrollBar.LineUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}" Command="ScrollBar.LineDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="10" />
                                <Setter Property="Width" Value="Auto" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}" />

        <!-- 次级按钮 -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource QuietButton}" />

        <!-- 菜单 -->
        <Style x:Key="CompactContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinWidth" Value="190" />
            <Setter Property="MaxHeight" Value="620" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="5">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18" ShadowDepth="5" Opacity="0.32" Color="#000000" />
                            </Border.Effect>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="11,7" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="ItemBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="5"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="14" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      VerticalAlignment="Center" />
                                    <TextBlock x:Name="GestureText"
                                               Grid.Column="1"
                                               Text="{TemplateBinding InputGestureText}"
                                               Foreground="{DynamicResource MutedText}"
                                               FontSize="10"
                                               Margin="18,0,7,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="SubmenuArrow"
                                               Grid.Column="2"
                                               Text="›"
                                               FontSize="16"
                                               Foreground="{DynamicResource MutedText}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed" />
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   Placement="Right"
                                   HorizontalOffset="-2"
                                   VerticalOffset="-5"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource PanelBackground}"
                                        BorderBrush="{DynamicResource PanelBorder}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="5">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="18" ShadowDepth="5" Opacity="0.32" Color="#000000" />
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="620"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource NodeHeaderBackground}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource NodeHeaderBackground}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible" />
                                <Setter Property="MinWidth" Value="184" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter Property="MinWidth" Value="184" />
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                                <Setter TargetName="GestureText" Property="Visibility" Value="Collapsed" />
                                <Setter Property="MinWidth" Value="0" />
                                <Setter Property="Padding" Value="11,7" />
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter TargetName="GestureText" Property="Visibility" Value="Collapsed" />
                                <Setter Property="MinWidth" Value="0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 状态栏 -->
        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}" />
        </Style>

        <!-- GridSplitter 样式（带细线反馈） -->
        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="{DynamicResource PanelBorder}" />
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Grid Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <Border x:Name="VerticalLine"
                                    Width="2"
                                    Background="{DynamicResource PanelBorder}"
                                    Opacity="0.6"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Stretch" />
                            <Border x:Name="HorizontalLine"
                                    Height="2"
                                    Background="{DynamicResource PanelBorder}"
                                    Opacity="0.6"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Stretch" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="VerticalLine" Property="Background" Value="{DynamicResource AccentHover}" />
                                <Setter TargetName="HorizontalLine" Property="Background" Value="{DynamicResource AccentHover}" />
                                <Setter TargetName="VerticalLine" Property="Opacity" Value="1" />
                                <Setter TargetName="HorizontalLine" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="VerticalLine" Property="Background" Value="{DynamicResource AccentPressed}" />
                                <Setter TargetName="HorizontalLine" Property="Background" Value="{DynamicResource AccentPressed}" />
                                <Setter TargetName="VerticalLine" Property="Opacity" Value="1" />
                                <Setter TargetName="HorizontalLine" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 节点列表项样式 -->
        <Style x:Key="NodeListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Accent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 节点库磁贴项样式 -->
        <Style x:Key="NodeLibraryTileItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="2" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Accent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        </Style>

        <!-- 子分类标签模板选择器 -->
        <local:NodeLibraryEntryTemplateSelector x:Key="NodeLibraryEntrySelector">
            <local:NodeLibraryEntryTemplateSelector.HeaderTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource PanelBackgroundAlt}"
                            BorderBrush="{DynamicResource PanelBorder}"
                            BorderThickness="0,0,0,1"
                            Padding="4,6,4,4"
                            Margin="0,4,0,4"
                            SnapsToDevicePixels="True">
                        <TextBlock Text="{Binding HeaderText}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedText}" />
                    </Border>
                </DataTemplate>
            </local:NodeLibraryEntryTemplateSelector.HeaderTemplate>
            <local:NodeLibraryEntryTemplateSelector.ItemTemplate>
                <DataTemplate>
                    <StackPanel Width="{Binding Path=NodeThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ThumbnailSizeConverter}}"
                                MinWidth="90"
                                Margin="2"
                                HorizontalAlignment="Center">
                        <Border Width="{Binding Path=NodeThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                Height="{Binding Path=NodeThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                CornerRadius="3"
                                Background="{Binding Item.PreviewBrush}"
                                BorderBrush="{DynamicResource ControlBorder}"
                                BorderThickness="1"
                                ToolTip="{Binding Item.Name}"
                                HorizontalAlignment="Center">
                            <Grid>
                                <Rectangle Fill="{Binding Item.PreviewBrush}" RadiusX="2" RadiusY="2" />
                                <Image Source="{Binding Item.PreviewImage}"
                                       Stretch="UniformToFill"
                                       SnapsToDevicePixels="True"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Item.PreviewImage}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </Grid>
                        </Border>
                        <TextBlock Text="{Binding Item.Name}"
                                   Foreground="{DynamicResource PrimaryText}"
                                   FontSize="11"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   LineHeight="16"
                                   Margin="0,2,0,0"
                                   MaxHeight="36" />
                    </StackPanel>
                </DataTemplate>
            </local:NodeLibraryEntryTemplateSelector.ItemTemplate>
        </local:NodeLibraryEntryTemplateSelector>

        <!-- ===== AI 消息模板（每种角色独立模板，避免 MarkdownViewer 被同时实例化） ===== -->

        <!-- 复制按钮样式：悬停气泡时显示，右下角小按钮，不遮挡文本 -->
        <Style x:Key="AiCopyButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Padding" Value="1" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTip" Value="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_CopyTooltip]}" />
            <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Content" Value="⊞" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                    <Setter Property="Opacity" Value="0.5" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 用户气泡：纯 TextBlock，右对齐 -->
        <DataTemplate x:Key="AiUserMessageTemplate">
            <Border HorizontalAlignment="Right"
                    MaxWidth="340"
                    CornerRadius="16,16,4,16"
                    Padding="12,8"
                    Margin="12,2,12,4"
                    Background="{DynamicResource Accent}">
                <DockPanel>
                    <Button Style="{StaticResource AiCopyButtonStyle}"
                            DockPanel.Dock="Right"
                            Click="AiCopyMessage_Click"
                            Tag="{Binding Content}" />
                    <TextBlock Text="{Binding Content}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource AccentForeground}"
                               FontSize="13" />
                </DockPanel>
            </Border>
        </DataTemplate>

        <!-- AI 助手气泡：流式时 TextBlock，完成后 MarkdownViewer -->
        <DataTemplate x:Key="AiAssistantMessageTemplate">
            <Border HorizontalAlignment="Left"
                    MaxWidth="400"
                    CornerRadius="4,16,16,16"
                    Padding="12,8"
                    Margin="12,2,12,4"
                    Background="{DynamicResource ControlBackground}">
                <DockPanel>
                    <Button Style="{StaticResource AiCopyButtonStyle}"
                            DockPanel.Dock="Right"
                            Click="AiCopyMessage_Click"
                            Tag="{Binding Content}" />
                    <StackPanel>
                        <!-- 角色标签 + 时间戳行 -->
                        <Grid MouseLeftButtonUp="AiReasoningHeader_MouseLeftButtonUp">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="{Binding ToggleGlyph}"
                                    Width="16" Height="16"
                                    Padding="0" Margin="0,0,4,0"
                                    FontSize="9"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{DynamicResource MutedText}"
                                    Click="AiReasoningToggle_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReasoning}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DisplayRole}"
                                       FontWeight="SemiBold"
                                       FontSize="10"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReasoning}" Value="True">
                                                <Setter Property="Foreground" Value="#E6B450" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Column="2"
                                       Margin="6,0,0,0"
                                       FontSize="9" Foreground="{DynamicResource MutedText}"
                                       VerticalAlignment="Center"
                                       Text="{Binding ReasoningStatusText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReasoning}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Column="3"
                                       Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                       FontSize="9" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource MutedText}" />
                        </Grid>
                        <!-- 推理折叠摘要 -->
                        <TextBlock Margin="20,2,0,0"
                                   Text="{Binding CollapsedSummary}"
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsReasoning}" Value="True" />
                                                <Condition Binding="{Binding IsCollapsed}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- 流式：轻量 TextBlock -->
                        <TextBlock Text="{Binding Content}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource PrimaryText}"
                                   FontSize="13"
                                   LineHeight="20">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsStreaming}" Value="True" />
                                                <Condition Binding="{Binding ShowContent}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- 完成：Markdown 渲染 -->
                        <controls:MarkdownViewer MarkdownText="{Binding Content}"
                                                 IsStreaming="{Binding IsStreaming}"
                                                 Margin="0,4,0,0"
                                                 Foreground="{DynamicResource PrimaryText}">
                            <controls:MarkdownViewer.Style>
                                <Style TargetType="controls:MarkdownViewer">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsStreaming}" Value="False" />
                                                <Condition Binding="{Binding ShowContent}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </controls:MarkdownViewer.Style>
                        </controls:MarkdownViewer>
                    </StackPanel>
                </DockPanel>
            </Border>
        </DataTemplate>

        <!-- 系统消息气泡 -->
        <DataTemplate x:Key="AiSystemMessageTemplate">
            <Border HorizontalAlignment="Center"
                    MaxWidth="380"
                    CornerRadius="6"
                    Padding="10,5"
                    Margin="12,2,12,4"
                    Background="{DynamicResource ControlBackground}">
                <TextBlock Text="{Binding Content}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource MutedText}"
                           FontSize="11"
                           TextAlignment="Center" />
            </Border>
        </DataTemplate>

        <!-- 错误消息气泡 -->
        <DataTemplate x:Key="AiErrorMessageTemplate">
            <Border HorizontalAlignment="Left"
                    MaxWidth="400"
                    CornerRadius="4,16,16,16"
                    Padding="12,8"
                    Margin="12,2,12,4"
                    Background="#2D1B1B">
                <DockPanel>
                    <Button Style="{StaticResource AiCopyButtonStyle}"
                            DockPanel.Dock="Right"
                            Foreground="#E07070"
                            Click="AiCopyMessage_Click"
                            Tag="{Binding Content}" />
                    <TextBlock Text="{Binding Content}"
                               TextWrapping="Wrap"
                               Foreground="#E07070"
                               FontSize="13" />
                </DockPanel>
            </Border>
        </DataTemplate>

        <!-- 工具调用组气泡 -->
        <DataTemplate x:Key="AiToolCallGroupTemplate">
            <Border HorizontalAlignment="Left"
                    MaxWidth="420"
                    CornerRadius="6"
                    Padding="8,6"
                    Margin="12,1,12,2"
                    Background="{DynamicResource PanelBackgroundAlt}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1">
                <StackPanel>
                    <!-- 组标题 -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{Binding StatusColor}"
                                   Text="{Binding StatusIcon, StringFormat='{} {0} Tool Calls'}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   FontSize="9"
                                   Foreground="{DynamicResource MutedText}"
                                   Text="{Binding Summary}"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- 每个工具调用步骤 -->
                    <ItemsControl ItemsSource="{Binding Steps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ControlBackground}"
                                        CornerRadius="4"
                                        Padding="6,4"
                                        Margin="0,2,0,2">
                                    <Grid MinHeight="20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 状态图标 -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding StatusIcon}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />

                                        <!-- 工具名 -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ToolName}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryText}"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0,6,0" />

                                        <!-- 右侧：参数摘要 或 结果预览 -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <!-- 参数摘要（显示在可读区域） -->
                                            <TextBlock Text="{Binding ArgumentsPreview}"
                                                       FontSize="9"
                                                       Foreground="{DynamicResource MutedText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxHeight="16" />
                                            <!-- 结果预览（完成时显示） -->
                                            <TextBlock Text="{Binding ResultPreview}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxHeight="18"
                                                       Margin="0,1,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="success">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="error">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- AI 消息模板选择器 -->
        <controls:AiMessageTemplateSelector x:Key="AiMsgSelector"
            UserTemplate="{StaticResource AiUserMessageTemplate}"
            AssistantTemplate="{StaticResource AiAssistantMessageTemplate}"
            SystemTemplate="{StaticResource AiSystemMessageTemplate}"
            ErrorTemplate="{StaticResource AiErrorMessageTemplate}"
            ToolCallGroupTemplate="{StaticResource AiToolCallGroupTemplate}" />

        <Style x:Key="WorkspacePanelTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="VerticalDockSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="ShowsPreview" Value="True" />
            <Setter Property="ResizeDirection" Value="Columns" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border x:Name="HitArea" Background="Transparent">
                            <Border x:Name="Divider"
                                    Width="1"
                                    HorizontalAlignment="Center"
                                    Background="{DynamicResource PanelBorder}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Divider" Property="Width" Value="2" />
                                <Setter TargetName="Divider" Property="Background" Value="{DynamicResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ============= 全新布局：现代简约 + 全面板可调 ============= -->
    <Grid xmlns:controls="clr-namespace:PixelAssetGenerator.Controls">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- 顶部菜单栏 -->
            <RowDefinition Height="*" />
            <!-- 主工作区 -->
            <RowDefinition Height="Auto" />
            <!-- 状态栏 -->
        </Grid.RowDefinitions>

        <!-- ========== 顶部命令栏 ========== -->
        <Border Grid.Row="0"
                Margin="8,8,8,0"
                Padding="12,9"
                Style="{StaticResource WorkspaceCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                    <Border Width="42" Height="42" CornerRadius="11" Background="{DynamicResource Accent}">
                        <TextBlock Text="PX" Foreground="{DynamicResource AccentForeground}"
                                   FontSize="12" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="9,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[AppTitle]}"
                                   FontSize="15" FontWeight="SemiBold" />
                        <TextBlock Text="PIXEL NODE STUDIO" FontSize="10" Foreground="{DynamicResource MutedText}" />
                    </StackPanel>
                </StackPanel>

                <Menu Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                    <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_File]}">
                        <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_OpenProjectFile]}" Click="OpenProjectMenuItem_Click" />
                        <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_SaveProjectFile]}" Click="SaveProjectMenuItem_Click" />
                        <Separator />
                        <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_ExportTiles]}" Click="SaveButton_Click" />
                        <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_BatchExportSeeds]}" Click="BatchSeedExport_Click" />
                    </MenuItem>
                    <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_AI_Settings]}" Click="AiSettingsMenuItem_Click" />
                </Menu>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_OpenProjectFile]}"
                            Style="{StaticResource CommandBarButton}"
                            Click="OpenProjectMenuItem_Click" />
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_SaveProjectFile]}"
                            Style="{StaticResource CommandBarButton}"
                            Margin="2,0,0,0"
                            Click="SaveProjectMenuItem_Click" />
                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_ExportTiles]}"
                            Style="{StaticResource AccentButton}"
                            Padding="14,6" Margin="6,0,0,0"
                            Click="SaveButton_Click" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,8,0">
                    <ToggleButton x:Name="LibraryPanelToggle"
                                  IsChecked="True"
                                  Style="{StaticResource WorkspaceToggleButton}"
                                  Checked="WorkspacePanelToggle_Changed"
                                  Unchecked="WorkspacePanelToggle_Changed"
                                  Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_NodeLibrary]}" />
                    <ToggleButton x:Name="InspectorPanelToggle"
                                  IsChecked="True"
                                  Margin="2,0,0,0"
                                  Style="{StaticResource WorkspaceToggleButton}"
                                  Checked="WorkspacePanelToggle_Changed"
                                  Unchecked="WorkspacePanelToggle_Changed"
                                  Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_NodeProperties]}" />
                    <ToggleButton x:Name="AssistantPanelToggle"
                                  IsChecked="True"
                                  Margin="2,0,0,0"
                                  Style="{StaticResource WorkspaceToggleButton}"
                                  Checked="WorkspacePanelToggle_Changed"
                                  Unchecked="WorkspacePanelToggle_Changed"
                                  Content="AI" />
                </StackPanel>

                <Button Grid.Column="4"
                        Width="34" Height="34" Padding="0"
                        Style="{StaticResource CommandBarButton}"
                        Content="⚙"
                        FontSize="14"
                        Click="SettingsButton_Click"
                        ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_OpenSettings]}" />
            </Grid>
        </Border>

        <!-- ========== 主工作区 Grid：四列可调（左库 | 画布 | 属性 | AI面板） ========== -->
        <Grid Grid.Row="1" Margin="8,8,8,6">
            <Grid.ColumnDefinitions>
                <!-- 左侧节点库面板 -->
                <ColumnDefinition x:Name="LeftPanelColumn" Width="320" MinWidth="260" />
                <ColumnDefinition x:Name="LeftPanelSplitterColumn" Width="8" />
                <!-- 中间画布+预览区 -->
                <ColumnDefinition Width="*" MinWidth="420" />
                <ColumnDefinition x:Name="CenterInspectorSplitterColumn" Width="8" />
                <!-- 右侧属性面板 -->
                <ColumnDefinition x:Name="InspectorPanelColumn" Width="320" MinWidth="260" />
                <ColumnDefinition x:Name="InspectorPanelSplitterColumn" Width="8" />
                <!-- AI 助手面板（仿 Claude 桌面版独立面板） -->
                <ColumnDefinition x:Name="AiPanelColumn" Width="360" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- ===== 左侧面板：节点库 + 模板 ===== -->
            <Border x:Name="LeftDockPanel"
                    Grid.Column="0"
                    Style="{StaticResource WorkspaceCardStyle}"
                    Padding="0">
                <TabControl x:Name="LeftPanelTabs"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Margin="0"
                            TabStripPlacement="Top">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Background" Value="{DynamicResource PanelBackground}" />
                            <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
                            <Setter Property="Padding" Value="14,8" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="TabBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{DynamicResource PanelBorder}"
                                                BorderThickness="0,0,0,1"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter ContentSource="Header"
                                                              RecognizesAccessKey="True" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource PanelBackground}" />
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,0,0,2" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>
                    <!-- Tab 1: 节点库 -->
                    <TabItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_NodeLibrary]}">
                        <Grid Margin="12,8,12,12"
                              TextElement.Foreground="{DynamicResource PrimaryText}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="{DynamicResource PanelBackground}"
                                    BorderBrush="{DynamicResource ControlBorder}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Margin="0,0,0,6"
                                    Padding="6,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="NodeLibrarySearchBox"
                                             TextChanged="NodeLibrarySearchBox_TextChanged"
                                             Background="{DynamicResource PanelBackground}"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource PrimaryText}"
                                             CaretBrush="{DynamicResource PrimaryText}"
                                             FontSize="12"
                                             VerticalAlignment="Center">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Opacity" Value="0.7" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_SearchNodes]}"
                                               Foreground="{DynamicResource MutedText}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"
                                               Visibility="{Binding ElementName=NodeLibrarySearchBox, Path=Text, Converter={StaticResource StringToVisibilityConverter}}" />
                                    <Button Grid.Column="1"
                                            x:Name="ClearSearchButton"
                                            Content="X"
                                            FontSize="10"
                                            Width="18" Height="18"
                                            Padding="0"
                                            Background="Transparent"
                                            Foreground="{DynamicResource MutedText}"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="ClearSearchButton_Click"
                                            Visibility="Collapsed" />
                                </Grid>
                            </Border>
                            <!-- Thumbnail size slider -->
                            <Border Grid.Row="1"
                                    Background="{DynamicResource PanelBackground}"
                                    BorderBrush="{DynamicResource ControlBorder}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Margin="0,0,0,6"
                                    Padding="6,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="S"
                                               FontSize="9"
                                               Foreground="{DynamicResource MutedText}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,4,0" />
                                    <Slider Grid.Column="1"
                                            Minimum="28"
                                            Maximum="120"
                                            Value="{Binding Path=NodeThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                            TickFrequency="4"
                                            IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource Accent}"
                                            Thumb.DragCompleted="NodeThumbnailSlider_DragCompleted" />
                                    <TextBlock Grid.Column="2"
                                               Text="L"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource MutedText}"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0" />
                                </Grid>
                            </Border>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <!-- 分类树 -->
                                <TreeView Grid.Column="0"
                                          ItemsSource="{Binding NodeLibraryCategories}"
                                          SelectedItemChanged="NodeLibraryTree_SelectedItemChanged"
                                          Background="{DynamicResource PanelBackground}"
                                          Foreground="{DynamicResource PrimaryText}"
                                          BorderBrush="{DynamicResource ControlBorder}"
                                          BorderThickness="1"
                                          Padding="4">
                                    <TreeView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" />
                                                <TextBlock Text="{Binding Count, StringFormat=' ({0})'}"
                                                           Foreground="{DynamicResource MutedText}"
                                                           FontSize="10"
                                                           Margin="4,0,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                                <!-- 节点列表（磁贴视图） -->
                                <ScrollViewer Grid.Column="2"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              PanningMode="Both"
                                              PanningDeceleration="0.002">
                                    <ListBox x:Name="NodeLibraryList"
                                             ItemContainerStyle="{StaticResource NodeLibraryTileItemStyle}"
                                             ItemTemplateSelector="{StaticResource NodeLibraryEntrySelector}"
                                             Background="{DynamicResource PanelBackground}"
                                             Foreground="{DynamicResource PrimaryText}"
                                             BorderBrush="{DynamicResource ControlBorder}"
                                             BorderThickness="1"
                                             Padding="4"
                                             PreviewMouseLeftButtonDown="NodeLibraryList_PreviewMouseLeftButtonDown"
                                             PreviewMouseMove="NodeLibraryList_PreviewMouseMove"
                                             SelectionChanged="NodeLibraryList_SelectionChanged"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             HorizontalContentAlignment="Stretch"
                                             VirtualizingPanel.IsVirtualizing="False">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel ItemWidth="{Binding Path=NodeThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ThumbnailSizeConverter}}" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                    </ListBox>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </TabItem>
                    <!-- Tab 2: 模板浏览器 -->
                    <TabItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Templates]}">
                        <Grid Margin="12,8,12,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_DragTemplateHint]}"
                                       Foreground="{DynamicResource MutedText}"
                                       FontSize="11"
                                       Margin="0,0,0,8" />
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ListBox x:Name="TemplateList"
                                         ItemsSource="{Binding TemplateFiles}"
                                         Background="{DynamicResource PanelBackground}"
                                         Foreground="{DynamicResource PrimaryText}"
                                         BorderBrush="{DynamicResource ControlBorder}"
                                         BorderThickness="1"
                                         Padding="4"
                                         AllowDrop="True"
                                         PreviewMouseMove="TemplateList_PreviewMouseMove">
                                    <ListBox.Resources>
                                        <ContextMenu x:Key="TemplateContextMenu"
                                                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Rename]}"
                                                      Click="RenameTemplateMenuItem_Click" />
                                            <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Delete]}"
                                                      Click="DeleteTemplateMenuItem_Click" />
                                        </ContextMenu>
                                    </ListBox.Resources>
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="80" Height="80" Margin="4"
                                                    CornerRadius="4"
                                                    BorderBrush="{DynamicResource ControlBorder}"
                                                    BorderThickness="1"
                                                    Background="{DynamicResource WindowBackground}"
                                                    ContextMenu="{StaticResource TemplateContextMenu}">
                                                <Grid>
                                                    <Image Source="{Binding PreviewPath}"
                                                           Width="64" Height="64"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasPreview}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Foreground="{DynamicResource PrimaryText}"
                                                               FontSize="10"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Bottom"
                                                               Margin="2,0,2,2">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasPreview}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </ScrollViewer>
                            <Button Grid.Row="2"
                                    Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_SaveAsTemplate]}"
                                    Margin="0,8,0,0"
                                    Padding="10,6"
                                    MinHeight="34"
                                    FontSize="12"
                                    Click="SaveAsTemplateMenuItem_Click"
                                    Style="{StaticResource MenuButton}" />
                        </Grid>
                    </TabItem>
                    <!-- Tab 3: Console -->
                    <TabItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Console]}"
                             x:Name="ConsoleTabItem">
                        <Grid Margin="12,8,12,12">
                            <controls:ConsoleControl x:Name="ConsoleControlHost" />
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <!-- 左侧分割条 -->
            <GridSplitter x:Name="LeftDockSplitter"
                          Grid.Column="1"
                          Style="{StaticResource VerticalDockSplitterStyle}" />

            <!-- ===== 中间区域：节点画布 + 预览（上下可调） ===== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" MinHeight="150" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" MinHeight="120" />
                </Grid.RowDefinitions>

                <!-- 节点画布 -->
                <Border Grid.Row="0"
                        Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource PanelCornerRadius}"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_NodeCanvas]}" Style="{StaticResource SectionTitle}" Margin="0" />
                            <TextBlock Grid.Column="1" Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_DragAndConnect]}" Foreground="{DynamicResource MutedText}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            <!-- Animation playback controls -->
                            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" x:Name="AnimControlPanel"
                                    Background="{DynamicResource ControlBackground}"
                                    BorderBrush="{DynamicResource ControlBorder}"
                                    BorderThickness="1" CornerRadius="8"
                                    Padding="8,5" Margin="0,8,0,0"
                                    HorizontalAlignment="Left"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="AnimPrevBtn" Content="‹" Width="30" Height="30" FontSize="18"
                                             Padding="0" ToolTip="上一帧" Click="AnimPrev_Click"
                                             Background="Transparent" Foreground="{DynamicResource MutedText}" BorderThickness="0" Cursor="Hand" />
                                    <Button x:Name="AnimPlayBtn" Content="▶  播放" MinWidth="76" Height="30" FontSize="12"
                                             Padding="10,0" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_AnimPlay]}"
                                             Click="AnimPlay_Click"
                                             Background="{DynamicResource Accent}" Foreground="{DynamicResource AccentForeground}" BorderThickness="0" Cursor="Hand" />
                                    <Button x:Name="AnimStopBtn" Content="■  停止" MinWidth="70" Height="30" FontSize="12"
                                             Padding="10,0" Margin="4,0,0,0" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_AnimStop]}"
                                             Click="AnimStop_Click"
                                             Background="Transparent" Foreground="{DynamicResource MutedText}" BorderThickness="0" Cursor="Hand" />
                                    <Button x:Name="AnimStepBtn" Content="›" Width="30" Height="30" FontSize="18"
                                             Padding="0" Margin="2,0,0,0" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_AnimNextFrame]}"
                                             Click="AnimStep_Click"
                                             Background="Transparent" Foreground="{DynamicResource MutedText}" BorderThickness="0" Cursor="Hand" />
                                    <TextBlock x:Name="AnimPlaybackStatusText"
                                               Text="已暂停" FontSize="11"
                                               Foreground="{DynamicResource MutedText}"
                                               VerticalAlignment="Center" Margin="5,0,0,0" />
                                    <Separator Width="1" Background="{DynamicResource ControlBorder}" Margin="4,2" />
                                    <TextBlock x:Name="AnimFrameLabel" Text="1/8"
                                               FontSize="10" VerticalAlignment="Center"
                                               Foreground="{DynamicResource MutedText}" Margin="0,0,4,0" />
                                    <Slider x:Name="AnimTimelineSlider"
                                            Width="156" Height="24" Minimum="0" Maximum="7" Value="0"
                                            TickFrequency="1" IsSnapToTickEnabled="True"
                                            AutoToolTipPlacement="TopLeft" AutoToolTipPrecision="0"
                                            ToolTip="拖动时间轴定位动画帧"
                                            ValueChanged="AnimTimelineSlider_ValueChanged"
                                            Margin="0,0,5,0" VerticalAlignment="Center" />
                                    <TextBlock x:Name="AnimTimeLabel" Text="0.00s" Width="42"
                                               FontSize="11" VerticalAlignment="Center"
                                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,4,0" />
                                    <TextBlock Text="帧" FontSize="10"
                                               Foreground="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,2,0" />
                                    <ComboBox x:Name="AnimFrameCountCombo" Width="58" Height="30" FontSize="11"
                                              SelectedIndex="0" BorderThickness="1"
                                              ToolTip="动画总帧数"
                                              SelectionChanged="AnimFrameCountCombo_SelectionChanged"
                                              Foreground="{DynamicResource PrimaryText}"
                                              Background="{DynamicResource ControlBackground}">
                                        <ComboBoxItem Content="8" Tag="8" />
                                        <ComboBoxItem Content="12" Tag="12" />
                                        <ComboBoxItem Content="16" Tag="16" />
                                        <ComboBoxItem Content="24" Tag="24" />
                                        <ComboBoxItem Content="32" Tag="32" />
                                        <ComboBoxItem Content="64" Tag="64" />
                                    </ComboBox>
                                    <Separator Width="1" Background="{DynamicResource ControlBorder}" Margin="4,2" />
                                    <TextBlock Text="FPS" FontSize="10"
                                               Foreground="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,2,0" />
                                    <ComboBox x:Name="AnimFpsCombo" Width="60" Height="30" FontSize="11"
                                              SelectedIndex="2" BorderThickness="1"
                                              SelectionChanged="AnimFpsCombo_SelectionChanged"
                                              Foreground="{DynamicResource PrimaryText}"
                                              Background="{DynamicResource ControlBackground}">
                                        <ComboBoxItem Content="6" Tag="6" />
                                        <ComboBoxItem Content="8" Tag="8" />
                                        <ComboBoxItem Content="12" Tag="12" />
                                        <ComboBoxItem Content="15" Tag="15" />
                                        <ComboBoxItem Content="24" Tag="24" />
                                        <ComboBoxItem Content="30" Tag="30" />
                                    </ComboBox>
                                    <ComboBox x:Name="AnimPlayModeCombo" Width="78" Height="30" FontSize="11"
                                              SelectedIndex="0" BorderThickness="1" Margin="4,0,0,0"
                                              ToolTip="播放模式"
                                              SelectionChanged="AnimPlayModeCombo_SelectionChanged"
                                              Foreground="{DynamicResource PrimaryText}"
                                              Background="{DynamicResource ControlBackground}">
                                        <ComboBoxItem Content="循环" Tag="Loop" />
                                        <ComboBoxItem Content="往返" Tag="PingPong" />
                                        <ComboBoxItem Content="单次" Tag="SingleShot" />
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <!-- 画布宿主：保留原有所有命名控件 -->
                        <Border x:Name="NodeCanvasHost"
                                Grid.Row="1"
                                Background="{DynamicResource WindowBackground}"
                                CornerRadius="10"
                                Padding="4"
                                ClipToBounds="True"
                                AllowDrop="True"
                                DragOver="NodeCanvasHost_DragOver" 
                                Drop="NodeCanvasHost_Drop" 
                                PreviewMouseWheel="NodeCanvasHost_PreviewMouseWheel" 
                                PreviewMouseDown="NodeCanvasHost_PreviewMouseDown" 
                                PreviewMouseMove="NodeCanvasHost_PreviewMouseMove" 
                                PreviewMouseUp="NodeCanvasHost_PreviewMouseUp" 
                                ContextMenuOpening="NodeCanvasHost_ContextMenuOpening"
                                PreviewMouseRightButtonUp="NodeCanvasHost_PreviewMouseRightButtonUp">
                            <Border.ContextMenu>
                                <ContextMenu Style="{StaticResource CompactContextMenuStyle}" Opened="CanvasContextMenu_Opened">
                                    <MenuItem Header="添加节点" Tag="CanvasAddRoot" />
                                    <MenuItem Header="预设" Tag="CanvasPresetRoot" />
                                    <MenuItem Header="使用帮助" Click="Context_ShowAnimationParticleHelp_Click" />
                                    <Separator />
                                    <MenuItem Header="粘贴" InputGestureText="Ctrl+V" Tag="CanvasPaste" Click="Context_Paste_Click" />
                                    <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_SelectAll]}" InputGestureText="Ctrl+A" Click="Context_SelectAll_Click" />
                                    <MenuItem Header="删除所选" InputGestureText="Delete" Tag="CanvasDelete" Click="Context_DeleteSelected_Click" />
                                    <Separator />
                                    <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_AutoArrangeNodes]}" Click="Context_AutoLayout_Click" />
                                </ContextMenu>
                            </Border.ContextMenu>
                            <!-- 画布视口（包含网格、连线、节点等）完全保留 -->
                            <Grid x:Name="NodeCanvasViewport">
                                <local:InfiniteGrid x:Name="InfiniteGrid"
                                                    Scale="{Binding NodeCanvasScale}"
                                                    OffsetX="{Binding NodeCanvasOffsetX}"
                                                    OffsetY="{Binding NodeCanvasOffsetY}"
                                                    MajorSpacing="64"
                                                    MinorSpacing="16"
                                                    MinorBrush="{StaticResource FineGridBrush}"
                                                    MajorBrush="{StaticResource CoarseGridBrush}"
                                                    Panel.ZIndex="0"
                                                    UseLayoutRounding="False"
                                                    SnapsToDevicePixels="False"
                                                    RenderOptions.BitmapScalingMode="Linear" />
                                <Rectangle x:Name="SelectionMarquee"
                                           Visibility="Collapsed"
                                           IsHitTestVisible="False"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top"
                                           Fill="#2066B2FF"
                                           Stroke="{DynamicResource Accent}"
                                           StrokeThickness="1"
                                           RadiusX="3"
                                           RadiusY="3"
                                           Panel.ZIndex="2" />
                                <!-- 语义控制面板 -->
                                <Border x:Name="SemanticControlPanel"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Stretch"
                                        Background="{DynamicResource PanelBackgroundAlt}"
                                        BorderBrush="{DynamicResource PanelBorder}"
                                        BorderThickness="0,0,0,1"
                                        Padding="8,4"
                                        Panel.ZIndex="10"
                                        Visibility="Collapsed">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNode.Title, RelativeSource={RelativeSource AncestorType=Window}}" Value="语义控制">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                        <StackPanel Orientation="Horizontal">
                                            <ItemsControl ItemsSource="{Binding SelectedNode.Parameters, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Vertical" Margin="8,0" Width="90">
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static local:NodeParameterKind.Boolean}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       Foreground="{DynamicResource MutedText}"
                                                                       FontSize="10"
                                                                       TextAlignment="Center" />
                                                            <Slider Minimum="{Binding Min}"
                                                                    Maximum="{Binding Max}"
                                                                    SmallChange="0.01"
                                                                    LargeChange="0.1"
                                                                    Value="{Binding NumberValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    Height="18" />
                                                            <TextBlock Text="{Binding NumberValue, StringFormat=F2}"
                                                                       Foreground="{DynamicResource PrimaryText}"
                                                                       FontSize="10"
                                                                       TextAlignment="Center"
                                                                       PreviewMouseLeftButtonDown="NumberValueText_MouseDown"
                                                                       PreviewMouseMove="NumberValueText_MouseMove"
                                                                       PreviewMouseLeftButtonUp="NumberValueText_MouseUp"
                                                                       Cursor="SizeWE" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                                <Grid x:Name="NodeCanvasSurface" RenderTransformOrigin="0,0" Panel.ZIndex="1">
                                    <Grid.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="{Binding NodeCanvasScale}" ScaleY="{Binding NodeCanvasScale}" />
                                            <TranslateTransform X="{Binding NodeCanvasOffsetX}" Y="{Binding NodeCanvasOffsetY}" />
                                        </TransformGroup>
                                    </Grid.RenderTransform>
                                    <Canvas x:Name="NodeConnectionLayer"
                                            Panel.ZIndex="0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Width="{Binding NodeCanvasWidth}"
                                            Height="{Binding NodeCanvasHeight}">
                                        <ItemsControl ItemsSource="{Binding NodeConnectionsView}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Canvas MouseLeftButtonDown="ConnectionLine_MouseLeftButtonDown">
                                                        <!-- 透明宽路径用于扩大点击区域 -->
                                                        <Path Data="{Binding WireGeometry}"
                                                              Stroke="Transparent"
                                                              StrokeThickness="10"
                                                              Fill="Transparent"
                                                              Cursor="Hand" />
                                                        <!-- 深色描边让不同背景上的连线都保持清楚 -->
                                                        <Path Data="{Binding WireGeometry}"
                                                              Stroke="#9A10141D"
                                                              StrokeThickness="5"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              Fill="Transparent"
                                                              IsHitTestVisible="False" />
                                                        <!-- 可见贝塞尔连线 -->
                                                        <Path Data="{Binding WireGeometry}"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              Fill="Transparent"
                                                              IsHitTestVisible="False">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Setter Property="Stroke" Value="{Binding WireBrush}" />
                                                                    <Setter Property="StrokeThickness" Value="2.4" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Stroke" Value="#FFD966" />
                                                                            <Setter Property="StrokeThickness" Value="3.2" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Canvas>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Canvas>
                                    <ItemsControl x:Name="NodeCanvasItems" 
                                                  ItemsSource="{Binding NodeCanvasView}" 
                                                  Panel.ZIndex="1"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Top">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas x:Name="NodeCanvas"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Width="{Binding NodeCanvasWidth}"
                                                        Height="{Binding NodeCanvasHeight}" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource NodeBackground}"
                                                        CornerRadius="6"
                                                        Padding="6"
                                                        Width="180"
                                                        MouseLeftButtonDown="NodeItem_MouseLeftButtonDown"
                                                        MouseLeftButtonUp="NodeItem_MouseLeftButtonUp"
                                                        MouseMove="NodeItem_MouseMove">
                                                    <Border.ContextMenu>
                                                        <ContextMenu Style="{StaticResource CompactContextMenuStyle}"
                                                                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                                     Opened="NodeContextMenu_Opened">
                                                            <MenuItem Header="重命名" InputGestureText="F2" Click="Node_Context_Rename_Click" />
                                                            <Separator />
                                                            <MenuItem Header="复制" InputGestureText="Ctrl+C" Click="Node_Context_Copy_Click" />
                                                            <MenuItem Header="副本" InputGestureText="Ctrl+D" Click="Node_Context_Duplicate_Click" />
                                                            <Separator />
                                                            <MenuItem Header="移动">
                                                                <MenuItem Header="视图居中" Click="Node_Context_MoveToViewCenter_Click" />
                                                                <Separator />
                                                                <MenuItem Header="左移 16 px" Tag="left" Click="Node_Context_Nudge_Click" />
                                                                <MenuItem Header="右移 16 px" Tag="right" Click="Node_Context_Nudge_Click" />
                                                                <MenuItem Header="上移 16 px" Tag="up" Click="Node_Context_Nudge_Click" />
                                                                <MenuItem Header="下移 16 px" Tag="down" Click="Node_Context_Nudge_Click" />
                                                            </MenuItem>
                                                            <MenuItem Header="断开连接" Click="Node_Context_Disconnect_Click" />
                                                            <MenuItem Header="保存为预设" Click="Node_Context_SaveAsTemplate_Click" />
                                                            <Separator />
                                                            <MenuItem Header="删除" InputGestureText="Delete" Click="Node_Context_Delete_Click" />
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource NodeBorder}" />
                                                            <!-- Keep thickness stable so selection never shifts port centers. -->
                                                            <Setter Property="BorderThickness" Value="2" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <Border Background="{DynamicResource NodeHeaderBackground}" CornerRadius="4" Padding="4" Margin="0,0,0,4">
                                                            <DockPanel>
                                                                <Border Width="24"
                                                                        Height="24"
                                                                        Background="{Binding PreviewBrush}"
                                                                        BorderBrush="{DynamicResource ControlBorder}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="3"
                                                                        Margin="0,0,6,0" />
                                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                            </DockPanel>
                                                        </Border>
                                                        <!-- Node center preview removed to simplify UI -->
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <ItemsControl ItemsSource="{Binding InputPorts}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,1">
                                                                            <Grid Width="14" Height="14" Margin="-13,0,3,0"
                                                                                  Background="Transparent" Cursor="Cross"
                                                                                  MouseEnter="NodePort_MouseEnter"
                                                                                  MouseLeave="NodePort_MouseLeave"
                                                                                  MouseLeftButtonDown="NodeInputPort_MouseLeftButtonDown"
                                                                                  MouseLeftButtonUp="NodeInputPort_MouseLeftButtonUp">
                                                                                <!-- Dark outline -->
                                                                                <Ellipse Stroke="#50000000" StrokeThickness="1" Fill="Transparent" IsHitTestVisible="False" />
                                                                                <!-- Main fill -->
                                                                                <Ellipse Margin="1" Fill="{Binding FillBrush}" IsHitTestVisible="False" />
                                                                                <!-- 3D convex gradient -->
                                                                                <Ellipse Margin="1" IsHitTestVisible="False">
                                                                                    <Ellipse.Fill>
                                                                                        <LinearGradientBrush StartPoint="0.3,0" EndPoint="0.7,1">
                                                                                            <GradientStop Color="#50FFFFFF" Offset="0" />
                                                                                            <GradientStop Color="#00FFFFFF" Offset="0.4" />
                                                                                            <GradientStop Color="#30000000" Offset="1" />
                                                                                        </LinearGradientBrush>
                                                                                    </Ellipse.Fill>
                                                                                </Ellipse>
                                                                            </Grid>
                                                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource MutedText}" VerticalAlignment="Center" />
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <ItemsControl Grid.Column="1" ItemsSource="{Binding OutputPorts}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,1" HorizontalAlignment="Right">
                                                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource MutedText}" Margin="0,0,3,0" VerticalAlignment="Center" />
                                                                            <Grid Width="14" Height="14" Margin="0,0,-13,0"
                                                                                  Background="Transparent" Cursor="Cross"
                                                                                  MouseEnter="NodePort_MouseEnter"
                                                                                  MouseLeave="NodePort_MouseLeave"
                                                                                  MouseLeftButtonDown="NodeOutputPort_MouseLeftButtonDown">
                                                                                <!-- Dark outline -->
                                                                                <Ellipse Stroke="#50000000" StrokeThickness="1" Fill="Transparent" IsHitTestVisible="False" />
                                                                                <!-- Main fill -->
                                                                                <Ellipse Margin="1" Fill="{Binding FillBrush}" IsHitTestVisible="False" />
                                                                                <!-- 3D convex gradient -->
                                                                                <Ellipse Margin="1" IsHitTestVisible="False">
                                                                                    <Ellipse.Fill>
                                                                                        <LinearGradientBrush StartPoint="0.3,0" EndPoint="0.7,1">
                                                                                            <GradientStop Color="#50FFFFFF" Offset="0" />
                                                                                            <GradientStop Color="#00FFFFFF" Offset="0.4" />
                                                                                            <GradientStop Color="#30000000" Offset="1" />
                                                                                        </LinearGradientBrush>
                                                                                    </Ellipse.Fill>
                                                                                </Ellipse>
                                                                            </Grid>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                                <TextBlock x:Name="NodeCanvasStats"
                                           IsHitTestVisible="False"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="8"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top"
                                           FontSize="11"
                                           Text="-- ms · -- fps" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- 画布与预览之间的分割条 -->
                <GridSplitter Grid.Row="1"
                              Height="2"
                              ResizeDirection="Rows"
                              HorizontalAlignment="Stretch"
                              Background="{DynamicResource PanelBorder}"
                              ShowsPreview="True" />

                <!-- 预览区域 -->
                <Border Grid.Row="2"
                        Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}"
                        Padding="12">
                    <Grid x:Name="PreviewContentGrid" SizeChanged="PreviewGrid_SizeChanged">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <RadioButton x:Name="StillPreviewRadio"
                                             IsChecked="True"
                                             Style="{StaticResource PreviewTabRadioStyle}"
                                             Checked="StillPreviewRadio_Checked">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="12" Height="12" Margin="0,0,4,0">
                                            <Path Stroke="{DynamicResource PrimaryText}"
                                                  StrokeThickness="1.5"
                                                  StrokeLineJoin="Round"
                                                  Data="M2,2 L2,10 L6,10 L6,6 L10,6 L10,10 L14,10 L14,2 L2,2 Z" />
                                        </Viewbox>
                                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_StillFrame]}" />
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="AnimPreviewRadio"
                                             Margin="4,0,0,0"
                                             Style="{StaticResource PreviewTabRadioStyle}"
                                             Checked="AnimPreviewRadio_Checked">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="12" Height="12" Margin="0,0,4,0">
                                            <Path Stroke="{DynamicResource PrimaryText}"
                                                  StrokeThickness="1.5"
                                                  StrokeLineJoin="Round"
                                                  Data="M2,2 L6,6 L2,10 M8,2 L12,6 L8,10" />
                                        </Viewbox>
                                        <TextBlock Text="动画" />
                                    </StackPanel>
                                </RadioButton>
                                <TextBlock x:Name="ZoomText" Text="100%" Foreground="{DynamicResource MutedText}" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button x:Name="ZoomResetButton"
                                        ToolTip="{Binding FitPreviewToolTip, Source={x:Static local:SettingsService.Hints}}"
                                        Width="32"
                                        Height="28"
                                        Margin="0,0,6,0"
                                        Click="ZoomResetButton_Click"
                                        Style="{StaticResource MenuButton}">
                                    <Viewbox Width="16" Height="16">
                                        <Path Stroke="{DynamicResource PrimaryText}"
                                              StrokeThickness="1.8"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Fill="Transparent"
                                              Data="M5,1 L1,1 L1,5  M11,1 L15,1 L15,5  M5,15 L1,15 L1,11  M11,15 L15,15 L15,11" />
                                    </Viewbox>
                                </Button>
                                <ToggleButton x:Name="PreviewGridToggleButton"
                                              ToolTip="{Binding TogglePreviewGridToolTip, Source={x:Static local:SettingsService.Hints}}"
                                              Width="36"
                                              Height="26"
                                              Margin="0,0,6,0"
                                              Click="PreviewGridToggleButton_Click"
                                              Style="{StaticResource MenuToggleButton}">
                                    <Grid Width="15" Height="15" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Row="0" Grid.Column="0" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="0" Grid.Column="1" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="0" Grid.Column="2" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="1" Grid.Column="0" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="1" Grid.Column="1" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="1" Grid.Column="2" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="2" Grid.Column="0" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="2" Grid.Column="1" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="2" Grid.Column="2" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                    </Grid>
                                </ToggleButton>
                                <ToggleButton x:Name="TileToggleButton"
                                              ToolTip="{Binding ToggleTilePreviewToolTip, Source={x:Static local:SettingsService.Hints}}"
                                              Width="36"
                                              Height="26"
                                              Margin="0,0,6,0"
                                              Click="TileToggleButton_Click"
                                              Style="{StaticResource MenuToggleButton}">
                                    <TextBlock Text="▦" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </ToggleButton>
                                <Separator Width="1" Background="{DynamicResource ControlBorder}" Margin="4,2" />
                                <ToggleButton x:Name="ComparisonToggleButton"
                                              ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_ComparisonMode]}"
                                              Width="36"
                                              Height="26"
                                              Margin="0,0,0,0"
                                              Click="ComparisonToggleButton_Click"
                                              Style="{StaticResource MenuToggleButton}">
                                    <Grid Width="14" Height="14">
                                        <Rectangle Fill="{DynamicResource PrimaryText}" Opacity="0.9">
                                            <Rectangle.OpacityMask>
                                                <VisualBrush Stretch="Fill">
                                                    <VisualBrush.Visual>
                                                        <Rectangle Width="14" Height="14" Fill="White" />
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                        <Line X1="7" Y1="0" X2="7" Y2="14" Stroke="{DynamicResource PanelBackground}" StrokeThickness="1.5" />
                                    </Grid>
                                </ToggleButton>
                            </StackPanel>
                        </Grid>

                        <!-- Frame slider bar for Still mode (hidden by default) -->
                        <Border x:Name="StillFrameSliderBar"
                                Grid.Row="1"
                                Background="{DynamicResource ControlBackground}"
                                BorderBrush="{DynamicResource ControlBorder}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="8,2"
                                Margin="0,0,0,6"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Frame]}" FontSize="10"
                                           Foreground="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <Slider x:Name="StillFrameSlider"
                                        Grid.Column="1"
                                        Minimum="0"
                                        Maximum="1"
                                        Value="0"
                                        SmallChange="0.01"
                                        LargeChange="0.1"
                                        ValueChanged="StillFrameSlider_ValueChanged"
                                        VerticalAlignment="Center" />
                                <TextBlock x:Name="StillFrameLabel"
                                           Grid.Column="2"
                                           Text="1/1"
                                           FontSize="10"
                                           Foreground="{DynamicResource MutedText}"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0" />
                            </Grid>
                        </Border>

                        <Border x:Name="PreviewViewport"
                                Grid.Row="2"
                                Background="{DynamicResource WindowBackground}"
                                CornerRadius="{StaticResource ControlCornerRadius}"
                                ClipToBounds="True"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Padding="8"
                                MouseWheel="PreviewContainer_MouseWheel">
                            <Grid x:Name="PreviewContainer"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  RenderTransformOrigin="0.5,0.5"
                                  RenderOptions.BitmapScalingMode="NearestNeighbor">
                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="PreviewScale" ScaleX="1" ScaleY="1" />
                                </Grid.RenderTransform>
                                <Rectangle x:Name="TiledPreviewSurface"
                                           Visibility="Collapsed"
                                           Stretch="Fill"
                                           SnapsToDevicePixels="True"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                <Image x:Name="PreviewImage"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                <Rectangle x:Name="PreviewPixelGridSurface"
                                           Visibility="Collapsed"
                                           IsHitTestVisible="False"
                                           SnapsToDevicePixels="True"
                                           RenderOptions.BitmapScalingMode="Linear"
                                           Panel.ZIndex="2"
                                           Fill="{StaticResource PreviewPixelGridBrush}"
                                           RenderOptions.EdgeMode="Aliased" />
                                <!-- Overlay for real-time preview pixel grid -->
                                <!-- Comparison mode: terminal node output when split enabled -->
                                <Image x:Name="ComparisonImage"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                <Rectangle x:Name="ComparisonDivider"
                                           Width="1"
                                           Fill="{DynamicResource PanelBorder}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Stretch"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- 中间分割条（中/右） -->
            <GridSplitter x:Name="CenterInspectorSplitter"
                          Grid.Column="3"
                          Style="{StaticResource VerticalDockSplitterStyle}" />

            <!-- ===== 右侧面板：三个可调整大小的垂直面板 ===== -->
            <Grid x:Name="InspectorDockPanel" Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MinHeight="100" />
                    <!-- 全局设置 -->
                    <RowDefinition Height="Auto" />
                    <!-- 分割条 -->
                    <RowDefinition Height="2*" MinHeight="150" />
                    <!-- 节点属性 -->
                    <RowDefinition Height="Auto" />
                    <!-- 分割条 -->
                    <RowDefinition Height="*" MinHeight="160" />
                    <!-- 节点列表 -->
                </Grid.RowDefinitions>

                <!-- 全局设置面板 -->
                <Border Grid.Row="0"
                        Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_GlobalSettings]}" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_TileSize]}" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ComboBox x:Name="TileSizeCombo" SelectedIndex="1" Margin="0,0,0,8" SelectionChanged="ParameterChanged">
                            <ComboBoxItem Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_16px], Mode=OneTime}" Tag="16" />
                            <ComboBoxItem Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_32px], Mode=OneTime}" Tag="32" />
                            <ComboBoxItem Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_64px], Mode=OneTime}" Tag="64" />
                            <!-- 128px removed: large pixel-art tiles produce poor results and are not commonly used -->
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- 分割条1 -->
                <GridSplitter Grid.Row="1"
                              Height="2"
                              ResizeDirection="Rows"
                              HorizontalAlignment="Stretch"
                              Background="{DynamicResource PanelBorder}"
                              ShowsPreview="True" />

                <!-- 节点属性面板（原有结构完整保留） -->
                <Border Grid.Row="2"
                        Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}"
                        MinHeight="0"
                        Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="127*"/>
                            <ColumnDefinition Width="67*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_NodeProperties]}" Style="{StaticResource SectionTitle}" Margin="0,0,0,8" Grid.Row="0" Grid.ColumnSpan="2" />

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Grid.ColumnSpan="2"
                                      PanningMode="Both" PanningDeceleration="0.002">
                            <StackPanel Margin="0,0,8,8">
                                <ContentControl Content="{Binding SelectedNode, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Style.Triggers>
                                                <Trigger Property="Content" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                    <ContentControl.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding SelectedNode.RegistryKey, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NodeDescriptionConverter}}"
                                                           Style="{StaticResource FieldLabel}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource MutedText}"
                                                           FontSize="11"
                                                           Margin="0,0,0,8" />
                                                <StackPanel Margin="0,0,0,10">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedNode.RegistryKey, RelativeSource={RelativeSource AncestorType=Window}}" Value="AiImageGen">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>

                                                    <!-- Bundled model status is deliberately separate from generation. -->
                                                    <Border Padding="10" Margin="0,0,0,8" CornerRadius="6"
                                                            Background="{DynamicResource ControlBackground}"
                                                            BorderBrush="{DynamicResource PanelBorder}" BorderThickness="1">
                                                        <StackPanel>
                                                            <DockPanel Margin="0,0,0,7">
                                                                <TextBlock Text="1  内置模型" FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource PrimaryText}" />
                                                                <Border DockPanel.Dock="Right" Padding="6,2" CornerRadius="8"
                                                                        Background="{DynamicResource SurfaceHighlight}">
                                                                    <TextBlock Text="免下载 · A卡 Vulkan" FontSize="10" Foreground="{DynamicResource Accent}" />
                                                                </Border>
                                                            </DockPanel>
                                                            <TextBlock Text="{Binding AiImageModelStatus, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       FontSize="11" Foreground="{DynamicResource PrimaryText}" TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding AiImageTranslatorStatus, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       FontSize="10" Foreground="{DynamicResource MutedText}"
                                                                       TextWrapping="Wrap" Margin="0,2,0,0" />
                                                            <TextBlock Text="{Binding AiImageBackendStatus, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       FontSize="10" Foreground="{DynamicResource MutedText}" Margin="0,2,0,7" />

                                                            <TextBlock Text="内置模型目录（只读）" FontSize="10" Foreground="{DynamicResource MutedText}" />
                                                            <StackPanel Margin="0,3,0,7">
                                                                <TextBox Text="{Binding AiImageModelDirectories, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"
                                                                         IsReadOnly="True" Padding="6,4"
                                                                         ToolTip="{Binding AiImageModelDirectories, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                         TextWrapping="Wrap" MinHeight="68"
                                                                         VerticalContentAlignment="Top"
                                                                         HorizontalScrollBarVisibility="Disabled"
                                                                         VerticalScrollBarVisibility="Auto" />
                                                            </StackPanel>

                                                            <ProgressBar Minimum="0" Maximum="1" Height="5" Margin="0,0,0,6"
                                                                         Value="{Binding AiImageProgress, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}" />
                                                            <TextBlock Text="{Binding AiImageNodeStatus, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       FontSize="11" Foreground="{DynamicResource PrimaryText}"
                                                                       TextWrapping="Wrap" MinHeight="28" />
                                                        </StackPanel>
                                                    </Border>

                                                    <!-- Large, multiline prompt editor. Prompt fields are hidden from the generic list below. -->
                                                    <Border Padding="10" CornerRadius="6"
                                                            Background="{DynamicResource ControlBackground}"
                                                            BorderBrush="{DynamicResource Accent}" BorderThickness="1">
                                                        <StackPanel>
                                                            <TextBlock Text="2  风格、视角与提示词" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,3" />
                                                            <TextBlock Text="支持中文和英文；风格、视角与对象结构词会在生成时自动加入。"
                                                                       FontSize="10" Foreground="{DynamicResource MutedText}"
                                                                       TextWrapping="Wrap" Margin="0,0,0,7" />
                                                            <ItemsControl ItemsSource="{Binding SelectedNode.Parameters, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Margin="0,0,0,7">
                                                                            <StackPanel.Style>
                                                                                <Style TargetType="StackPanel">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Name}" Value="style">
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding Name}" Value="visualStyle">
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding Name}" Value="viewAngle">
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding Name}" Value="referenceMode">
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </StackPanel.Style>
                                                                            <DockPanel Margin="0,0,0,3">
                                                                                <TextBlock Text="{Binding DisplayName}" Style="{StaticResource FieldLabel}" />
                                                                                <Button DockPanel.Dock="Right" Content="↩" Width="20" Height="20" Padding="0"
                                                                                        ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_ResetParam]}"
                                                                                        Tag="{Binding}" Click="NodeParamReset_Click" Style="{StaticResource MenuButton}" />
                                                                            </DockPanel>
                                                                            <ComboBox ItemsSource="{Binding DisplayChoices}"
                                                                                      SelectedItem="{Binding SelectedDisplayChoice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <Border Background="{DynamicResource SurfaceHighlight}" CornerRadius="4"
                                                                    Padding="7,5" Margin="0,0,0,8">
                                                                <TextBlock Text="{Binding AiImagePresetSummary, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                           FontSize="10" Foreground="{DynamicResource Accent}" TextWrapping="Wrap" />
                                                            </Border>
                                                            <DockPanel Margin="0,0,0,8">
                                                                <TextBlock Text="输出尺寸" FontSize="10" Foreground="{DynamicResource MutedText}" />
                                                                <TextBlock DockPanel.Dock="Right"
                                                                           Text="{Binding AiImageOutputSizeText, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                           FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource Accent}" />
                                                            </DockPanel>

                                                            <ItemsControl ItemsSource="{Binding SelectedNode.Parameters, RelativeSource={RelativeSource AncestorType=Window}}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Margin="0,0,0,8">
                                                                            <StackPanel.Style>
                                                                                <Style TargetType="StackPanel">
                                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Name}" Value="prompt">
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding Name}" Value="negativePrompt">
                                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </StackPanel.Style>
                                                                            <DockPanel Margin="0,0,0,3">
                                                                                <TextBlock Text="{Binding DisplayName}" Style="{StaticResource FieldLabel}" />
                                                                                <Button DockPanel.Dock="Right" Content="↩" Width="20" Height="20" Padding="0"
                                                                                        ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_ResetParam]}"
                                                                                        Tag="{Binding}" Click="NodeParamReset_Click" Style="{StaticResource MenuButton}" />
                                                                            </DockPanel>
                                                                            <TextBox Text="{Binding TextValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                     AcceptsReturn="True" TextWrapping="Wrap"
                                                                                     Padding="7,6" VerticalContentAlignment="Top"
                                                                                     VerticalScrollBarVisibility="Auto"
                                                                                     SpellCheck.IsEnabled="False">
                                                                                <TextBox.Style>
                                                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                                                        <Setter Property="MinHeight" Value="68" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding Name}" Value="prompt">
                                                                                                <Setter Property="MinHeight" Value="112" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBox.Style>
                                                                            </TextBox>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>

                                                            <TextBlock Text="{Binding AiImageReferenceStatus, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                       FontSize="10" Foreground="{DynamicResource MutedText}"
                                                                       TextWrapping="Wrap" Margin="0,0,0,8" />
                                                            <WrapPanel>
                                                                <Button Content="开始生成 / 重新生成" Margin="0,0,6,4" Padding="12,6"
                                                                        IsEnabled="{Binding AiImageCanGenerate, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        Click="AiImageGenerate_Click" />
                                                                <Button Content="取消生成" Margin="0,0,0,4" Padding="9,6"
                                                                        IsEnabled="{Binding AiImageCanCancelGeneration, RelativeSource={RelativeSource AncestorType=Window}}"
