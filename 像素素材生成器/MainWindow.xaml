<Window x:Class="PixelAssetGenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PixelAssetGenerator"
        xmlns:controls="clr-namespace:PixelAssetGenerator.Controls"
        xmlns:media="clr-namespace:System.Windows.Media;assembly=PresentationCore"
        xmlns:loc="clr-namespace:PixelAssetGenerator.Services.Localization"
        xmlns:converters="clr-namespace:PixelAssetGenerator.Converters"
        mc:Ignorable="d"
        Title="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[AppTitle]}"
        Height="720" Width="1200" WindowState="Maximized"
        Background="{DynamicResource WindowBackground}" 
        Foreground="{DynamicResource PrimaryText}" 
        FontFamily="Segoe UI" 
        Loaded="MainWindow_Loaded" 
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="False"
        SnapsToDevicePixels="False">

    <Window.Resources>
        <local:ParameterMaxConverter x:Key="ParamMaxConverter" />
        <local:InverseScaleConverter x:Key="InverseScaleConverter" />
        <converters:SliderFillWidthConverter x:Key="SliderFillWidthConverter" />
        <!-- Color converters -->
        <local:ColorToBrushConverter x:Key="ColorToBrushConverter" />
        <local:ColorToHexConverter x:Key="ColorToHexConverter" />
        <local:NodeDescriptionConverter x:Key="NodeDescriptionConverter" />
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <local:ThumbnailSizeConverter x:Key="ThumbnailSizeConverter" />

        <!-- 网格笔刷 -->
        <!--
            为了在屏幕上呈现比一个物理像素更细的线条，WPF 的设备像素对齐会把非常小的 Thickness 四舍五入到最近的物理像素，
            导致设置 Thickness="0.1" 仍然看起来为 1 像素。
            采用的技巧是：在更大的瓷砖 (Viewport) 上以 1px 绘制线条，然后对整个 Brush 做缩放（ScaleTransform）——
            缩放后线条视觉上会小于 1px（例如这里缩放到 0.25，相当于 1 * 0.25 = 0.25px）。
            同时通过较低的 alpha 值保持细线柔和效果。
        -->
        <DrawingBrush x:Key="FineGridBrush" TileMode="Tile" Viewport="0,0,64,64" ViewportUnits="Absolute" Stretch="None">
            <!-- 将 Brush 缩放 0.25 倍，使得在 64x64 上绘制的 1px 线最终显示为 0.25px 的视觉效果 -->
            <DrawingBrush.Transform>
                <ScaleTransform ScaleX="0.25" ScaleY="0.25" />
            </DrawingBrush.Transform>
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="64,0" />
                            <LineGeometry StartPoint="0,0" EndPoint="0,64" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Pen>
                        <!-- 使用 1px 的矢量线并降低 alpha，使缩放后线条看起来非常细且柔和 -->
                        <Pen Brush="#0AFFFFFF" Thickness="1" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- Preview pixel grid brush: scaled inversely to the preview transform so lines stay thin when zoomed -->
        <DrawingBrush x:Key="PreviewPixelGridBrush" TileMode="Tile" Viewport="0,0,64,64" ViewportUnits="Absolute" Stretch="None">
            <!-- 改进：先将瓷砖上的 1px 线缩小到更细（0.125），再应用预览缩放的逆缩放，从而在放大/缩小时保持视觉粗细不变且线更细 -->
            <DrawingBrush.Transform>
                <TransformGroup>
                    <!-- 缩小到更细的子像素宽度 (0.125 -> 1 * 0.125 = 0.125px) -->
                    <ScaleTransform ScaleX="0.125" ScaleY="0.125" />
                    <!-- 逆向抵消预览缩放，使得网格线在缩放时看起来粗细不变 -->
                    <ScaleTransform ScaleX="{Binding ScaleX, ElementName=PreviewScale, Converter={StaticResource InverseScaleConverter}}" ScaleY="{Binding ScaleY, ElementName=PreviewScale, Converter={StaticResource InverseScaleConverter}}" />
                </TransformGroup>
            </DrawingBrush.Transform>
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="64,0" />
                            <LineGeometry StartPoint="0,0" EndPoint="0,64" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Pen>
                        <!-- 降低 alpha 并保留 1px 矢量线，在缩放与逆缩放组合下表现为更细且柔和的网格线 -->
                        <Pen Brush="#20FFFFFF" Thickness="1" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <DrawingBrush x:Key="CoarseGridBrush" TileMode="Tile" Viewport="0,0,256,256" ViewportUnits="Absolute" Stretch="None">
            <!-- 同样的缩放技巧：在更大的瓷砖上用 1px 绘制，然后缩放到 0.25，最终视觉间距仍为 64 -->
            <DrawingBrush.Transform>
                <ScaleTransform ScaleX="0.25" ScaleY="0.25" />
            </DrawingBrush.Transform>
            <DrawingBrush.Drawing>
                <GeometryDrawing>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="256,0" />
                            <LineGeometry StartPoint="0,0" EndPoint="0,256" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#18FFFFFF" Thickness="1" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- 基础文本样式 -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Setter Property="FontSize" Value="{DynamicResource AppFontSize}" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Setter Property="Margin" Value="0,2,0,6" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- 次级切换按钮 -->
        <Style x:Key="SecondaryToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource ControlCornerRadius}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Accent}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 数字输入框 -->
        <Style x:Key="RangeInputTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Width" Value="56" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="FontSize" Value="9" />
        </Style>

        <!-- 区域标题 -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        </Style>

        <!-- 展开器 -->
        <Style TargetType="Expander">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource ControlCornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <DockPanel>
                                <ToggleButton x:Name="HeaderSite"
                                              DockPanel.Dock="Top"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Content="{TemplateBinding Header}"
                                              FontWeight="SemiBold"
                                              FontSize="13"
                                              Foreground="{DynamicResource PrimaryText}"
                                              HorizontalContentAlignment="Left"
                                              Padding="4,3"
                                              Margin="0,0,0,4"
                                              FocusVisualStyle="{x:Null}"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent" SnapsToDevicePixels="True">
                                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpandSite"
                                                  ContentSource="Content" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="HeaderSite" Property="Margin" Value="0" />
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="HeaderSite" Property="Margin" Value="0,0,0,4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 字段标签 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>

        <!-- 文本框 -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4,2" />
            <!-- 按回车键提交编辑：通过样式统一处理，按 Enter 时会触发代码后端将绑定值推送到源 -->
            <EventSetter Event="PreviewKeyDown" Handler="TextBox_PreviewKeyDown_Commit" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource ControlCornerRadius}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 组合框 -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="TextElement.Foreground" Value="{DynamicResource PrimaryText}" />
            <Setter Property="TextElement.Background" Value="{DynamicResource ControlBackground}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource ControlCornerRadius}">
                                <ToggleButton x:Name="ToggleButton"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Foreground="{TemplateBinding Foreground}"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="20" />
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
                                        <Path Grid.Column="1"
                                              Fill="{TemplateBinding Foreground}"
                                              Data="M 0 0 L 4 4 L 8 0 Z"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                    </Grid>
                                </ToggleButton>
                            </Border>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Width="{TemplateBinding ActualWidth}"
                                        CornerRadius="{StaticResource ControlCornerRadius}"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer Margin="2"
                                                  MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                                  SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Accent}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentPressed}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 滑块 -->
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{DynamicResource Accent}" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="SmallChange" Value="0.01" />
            <Setter Property="LargeChange" Value="0.05" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Height" Value="22" />
            <Setter Property="IsHitTestVisible" Value="True" />
            <EventSetter Event="PreviewMouseWheel" Handler="Slider_PreviewMouseWheel" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" MinHeight="18" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <!-- TickBar -->
                            <TickBar x:Name="TopTick" Grid.Row="0" Visibility="Collapsed" />
                            <!-- Track background -->
                            <Border x:Name="TrackBackground"
                                    Grid.Row="1"
                                    Height="4"
                                    Margin="6,0"
                                    CornerRadius="2"
                                    Background="{DynamicResource ControlBackground}" />
                            <!-- Track fill (滑杆高亮部分，随值变化) -->
                            <Border Grid.Row="1"
                                    Height="4"
                                    Margin="6,0"
                                    CornerRadius="2"
                                    Background="{TemplateBinding Foreground}"
                                    Opacity="0.5"
                                    HorizontalAlignment="Left">
                                <Border.Width>
                                    <MultiBinding Converter="{StaticResource SliderFillWidthConverter}">
                                        <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}" />
                                        <Binding Path="Maximum" RelativeSource="{RelativeSource TemplatedParent}" />
                                        <Binding ElementName="TrackBackground" Path="ActualWidth" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb"
                                           Width="14" Height="14"
                                           Background="{DynamicResource ControlBackground}"
                                           BorderBrush="{TemplateBinding Foreground}"
                                           BorderThickness="2">
                                        <Thumb.Style>
                                            <Style TargetType="Thumb">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Ellipse Fill="{TemplateBinding Background}"
                                                                     Stroke="{TemplateBinding BorderBrush}"
                                                                     StrokeThickness="2"
                                                                     Width="14" Height="14" />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Thumb.Style>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                            <TickBar x:Name="BottomTick" Grid.Row="2" Visibility="Collapsed" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主题化 ScrollBar，使列表/滚动条与整体配色和谐 -->
        <Style x:Key="ScrollBarRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Make repeat buttons take no layout space so thumb can reach ends -->
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="0" />
            <Setter Property="Width" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <!-- Use min sizes instead of fixed size so thumb can stretch to track ends -->
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="Margin" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                SnapsToDevicePixels="True" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentHover}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentHover}" />
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentPressed}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentPressed}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}" Command="ScrollBar.LineUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarRepeatButtonStyle}" Command="ScrollBar.LineDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="10" />
                                <Setter Property="Width" Value="Auto" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主按钮 -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Accent}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForeground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource ControlCornerRadius}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentHover}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentPressed}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentPressed}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 次级按钮 -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
        </Style>

        <!-- 菜单 -->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource ControlBorder}"
                                BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Margin="4,0"
                                                  VerticalAlignment="Center"
                                                  ContentSource="Header" />
                                <Popup x:Name="Popup"
                                       Grid.Column="1"
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsSubmenuOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False">
                                    <Border Background="{DynamicResource PanelBackground}"
                                            BorderBrush="{DynamicResource PanelBorder}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource ControlCornerRadius}"
                                            Padding="4">
                                        <StackPanel IsItemsHost="True" />
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter Property="Padding" Value="8,4" />
                                <Setter Property="FontSize" Value="10" />
                                <Setter Property="MinHeight" Value="22" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 状态栏 -->
        <Style TargetType="StatusBar">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}" />
        </Style>

        <!-- GridSplitter 样式（带细线反馈） -->
        <Style TargetType="GridSplitter">
            <Setter Property="Background" Value="{DynamicResource PanelBorder}" />
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Grid Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <Border x:Name="VerticalLine"
                                    Width="2"
                                    Background="{DynamicResource PanelBorder}"
                                    Opacity="0.6"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Stretch" />
                            <Border x:Name="HorizontalLine"
                                    Height="2"
                                    Background="{DynamicResource PanelBorder}"
                                    Opacity="0.6"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Stretch" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="VerticalLine" Property="Background" Value="{DynamicResource AccentHover}" />
                                <Setter TargetName="HorizontalLine" Property="Background" Value="{DynamicResource AccentHover}" />
                                <Setter TargetName="VerticalLine" Property="Opacity" Value="1" />
                                <Setter TargetName="HorizontalLine" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="VerticalLine" Property="Background" Value="{DynamicResource AccentPressed}" />
                                <Setter TargetName="HorizontalLine" Property="Background" Value="{DynamicResource AccentPressed}" />
                                <Setter TargetName="VerticalLine" Property="Opacity" Value="1" />
                                <Setter TargetName="HorizontalLine" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 节点列表项样式 -->
        <Style x:Key="NodeListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Accent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 节点库磁贴项样式 -->
        <Style x:Key="NodeLibraryTileItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="2" />
            <Setter Property="Margin" Value="0,0,4,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Accent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
        </Style>

        <!-- 子分类标签模板选择器 -->
        <local:NodeLibraryEntryTemplateSelector x:Key="NodeLibraryEntrySelector">
            <local:NodeLibraryEntryTemplateSelector.HeaderTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource PanelBackgroundAlt}"
                            BorderBrush="{DynamicResource PanelBorder}"
                            BorderThickness="0,0,0,1"
                            Padding="4,6,4,4"
                            Margin="0,4,0,4"
                            SnapsToDevicePixels="True">
                        <TextBlock Text="{Binding HeaderText}"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedText}" />
                    </Border>
                </DataTemplate>
            </local:NodeLibraryEntryTemplateSelector.HeaderTemplate>
            <local:NodeLibraryEntryTemplateSelector.ItemTemplate>
                <DataTemplate>
                    <StackPanel Width="{Binding Path=NodeThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ThumbnailSizeConverter}}"
                                Margin="2"
                                HorizontalAlignment="Center">
                        <Border Width="{Binding Path=NodeThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                Height="{Binding Path=NodeThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                CornerRadius="3"
                                Background="{Binding Item.PreviewBrush}"
                                BorderBrush="{DynamicResource ControlBorder}"
                                BorderThickness="1"
                                ToolTip="{Binding Item.Name}"
                                HorizontalAlignment="Center">
                            <Grid>
                                <Rectangle Fill="{Binding Item.PreviewBrush}" RadiusX="2" RadiusY="2" />
                                <Image Source="{Binding Item.PreviewImage}"
                                       Stretch="UniformToFill"
                                       SnapsToDevicePixels="True"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Item.PreviewImage}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </Grid>
                        </Border>
                        <TextBlock Text="{Binding Item.Name}"
                                   Foreground="{DynamicResource PrimaryText}"
                                   FontSize="10"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0"
                                   MaxHeight="28" />
                    </StackPanel>
                </DataTemplate>
            </local:NodeLibraryEntryTemplateSelector.ItemTemplate>
        </local:NodeLibraryEntryTemplateSelector>

        <!-- ===== AI 消息模板（每种角色独立模板，避免 MarkdownViewer 被同时实例化） ===== -->

        <!-- 复制按钮样式：悬停气泡时显示，右下角小按钮，不遮挡文本 -->
        <Style x:Key="AiCopyButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Padding" Value="1" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTip" Value="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_CopyTooltip]}" />
            <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Content" Value="⊞" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                    <Setter Property="Opacity" Value="0.5" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 用户气泡：纯 TextBlock，右对齐 -->
        <DataTemplate x:Key="AiUserMessageTemplate">
            <Border HorizontalAlignment="Right"
                    MaxWidth="340"
                    CornerRadius="16,16,4,16"
                    Padding="12,8"
                    Margin="12,2,12,4"
                    Background="{DynamicResource Accent}">
                <DockPanel>
                    <Button Style="{StaticResource AiCopyButtonStyle}"
                            DockPanel.Dock="Right"
                            Click="AiCopyMessage_Click"
                            Tag="{Binding Content}" />
                    <TextBlock Text="{Binding Content}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource AccentForeground}"
                               FontSize="13" />
                </DockPanel>
            </Border>
        </DataTemplate>

        <!-- AI 助手气泡：流式时 TextBlock，完成后 MarkdownViewer -->
        <DataTemplate x:Key="AiAssistantMessageTemplate">
            <Border HorizontalAlignment="Left"
                    MaxWidth="400"
                    CornerRadius="4,16,16,16"
                    Padding="12,8"
                    Margin="12,2,12,4"
                    Background="{DynamicResource ControlBackground}">
                <DockPanel>
                    <Button Style="{StaticResource AiCopyButtonStyle}"
                            DockPanel.Dock="Right"
                            Click="AiCopyMessage_Click"
                            Tag="{Binding Content}" />
                    <StackPanel>
                        <!-- 角色标签 + 时间戳行 -->
                        <Grid MouseLeftButtonUp="AiReasoningHeader_MouseLeftButtonUp">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="{Binding ToggleGlyph}"
                                    Width="16" Height="16"
                                    Padding="0" Margin="0,0,4,0"
                                    FontSize="9"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{DynamicResource MutedText}"
                                    Click="AiReasoningToggle_Click">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReasoning}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DisplayRole}"
                                       FontWeight="SemiBold"
                                       FontSize="10"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource Accent}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReasoning}" Value="True">
                                                <Setter Property="Foreground" Value="#E6B450" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Column="2"
                                       Margin="6,0,0,0"
                                       FontSize="9" Foreground="{DynamicResource MutedText}"
                                       VerticalAlignment="Center"
                                       Text="{Binding ReasoningStatusText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsReasoning}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Column="3"
                                       Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                       FontSize="9" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource MutedText}" />
                        </Grid>
                        <!-- 推理折叠摘要 -->
                        <TextBlock Margin="20,2,0,0"
                                   Text="{Binding CollapsedSummary}"
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="{DynamicResource MutedText}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsReasoning}" Value="True" />
                                                <Condition Binding="{Binding IsCollapsed}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- 流式：轻量 TextBlock -->
                        <TextBlock Text="{Binding Content}"
                                   Margin="0,4,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource PrimaryText}"
                                   FontSize="13"
                                   LineHeight="20">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsStreaming}" Value="True" />
                                                <Condition Binding="{Binding ShowContent}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- 完成：Markdown 渲染 -->
                        <controls:MarkdownViewer MarkdownText="{Binding Content}"
                                                 IsStreaming="{Binding IsStreaming}"
                                                 Margin="0,4,0,0"
                                                 Foreground="{DynamicResource PrimaryText}">
                            <controls:MarkdownViewer.Style>
                                <Style TargetType="controls:MarkdownViewer">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsStreaming}" Value="False" />
                                                <Condition Binding="{Binding ShowContent}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </controls:MarkdownViewer.Style>
                        </controls:MarkdownViewer>
                    </StackPanel>
                </DockPanel>
            </Border>
        </DataTemplate>

        <!-- 系统消息气泡 -->
        <DataTemplate x:Key="AiSystemMessageTemplate">
            <Border HorizontalAlignment="Center"
                    MaxWidth="380"
                    CornerRadius="6"
                    Padding="10,5"
                    Margin="12,2,12,4"
                    Background="{DynamicResource ControlBackground}">
                <TextBlock Text="{Binding Content}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource MutedText}"
                           FontSize="11"
                           TextAlignment="Center" />
            </Border>
        </DataTemplate>

        <!-- 错误消息气泡 -->
        <DataTemplate x:Key="AiErrorMessageTemplate">
            <Border HorizontalAlignment="Left"
                    MaxWidth="400"
                    CornerRadius="4,16,16,16"
                    Padding="12,8"
                    Margin="12,2,12,4"
                    Background="#2D1B1B">
                <DockPanel>
                    <Button Style="{StaticResource AiCopyButtonStyle}"
                            DockPanel.Dock="Right"
                            Foreground="#E07070"
                            Click="AiCopyMessage_Click"
                            Tag="{Binding Content}" />
                    <TextBlock Text="{Binding Content}"
                               TextWrapping="Wrap"
                               Foreground="#E07070"
                               FontSize="13" />
                </DockPanel>
            </Border>
        </DataTemplate>

        <!-- 工具调用组气泡 -->
        <DataTemplate x:Key="AiToolCallGroupTemplate">
            <Border HorizontalAlignment="Left"
                    MaxWidth="420"
                    CornerRadius="6"
                    Padding="8,6"
                    Margin="12,1,12,2"
                    Background="{DynamicResource PanelBackgroundAlt}"
                    BorderBrush="{DynamicResource ControlBorder}"
                    BorderThickness="1">
                <StackPanel>
                    <!-- 组标题 -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{Binding StatusColor}"
                                   Text="{Binding StatusIcon, StringFormat='{} {0} Tool Calls'}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   FontSize="9"
                                   Foreground="{DynamicResource MutedText}"
                                   Text="{Binding Summary}"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- 每个工具调用步骤 -->
                    <ItemsControl ItemsSource="{Binding Steps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource ControlBackground}"
                                        CornerRadius="4"
                                        Padding="6,4"
                                        Margin="0,2,0,2">
                                    <Grid MinHeight="20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 状态图标 -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding StatusIcon}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />

                                        <!-- 工具名 -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ToolName}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryText}"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0,6,0" />

                                        <!-- 右侧：参数摘要 或 结果预览 -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <!-- 参数摘要（显示在可读区域） -->
                                            <TextBlock Text="{Binding ArgumentsPreview}"
                                                       FontSize="9"
                                                       Foreground="{DynamicResource MutedText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxHeight="16" />
                                            <!-- 结果预览（完成时显示） -->
                                            <TextBlock Text="{Binding ResultPreview}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource PrimaryText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxHeight="18"
                                                       Margin="0,1,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="success">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="error">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- AI 消息模板选择器 -->
        <controls:AiMessageTemplateSelector x:Key="AiMsgSelector"
            UserTemplate="{StaticResource AiUserMessageTemplate}"
            AssistantTemplate="{StaticResource AiAssistantMessageTemplate}"
            SystemTemplate="{StaticResource AiSystemMessageTemplate}"
            ErrorTemplate="{StaticResource AiErrorMessageTemplate}"
            ToolCallGroupTemplate="{StaticResource AiToolCallGroupTemplate}" />

    </Window.Resources>

    <!-- ============= 全新布局：现代简约 + 全面板可调 ============= -->
    <Grid xmlns:controls="clr-namespace:PixelAssetGenerator.Controls">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- 顶部菜单栏 -->
            <RowDefinition Height="*" />
            <!-- 主工作区 -->
            <RowDefinition Height="Auto" />
            <!-- 状态栏 -->
        </Grid.RowDefinitions>

        <!-- ========== 顶部菜单栏 ========== -->
        <Border Grid.Row="0" 
                Margin="12,12,12,0" 
                Background="{DynamicResource PanelBackground}" 
                BorderBrush="{DynamicResource PanelBorder}" 
                BorderThickness="1" 
                CornerRadius="{StaticResource ControlCornerRadius}" 
                Padding="12,6">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Menu>
                        <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_File]}">
                            <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_OpenProjectFile]}" Click="OpenProjectMenuItem_Click" />
                            <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_SaveProjectFile]}" Click="SaveProjectMenuItem_Click" />
                            <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_ExportTiles]}" Click="SaveButton_Click" />
                            <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_BatchExportSeeds]}" Click="BatchSeedExport_Click" />
                        </MenuItem>
                        <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_AI_Settings]}" Click="AiSettingsMenuItem_Click" />
                    </Menu>
                    <Button Style="{StaticResource MenuButton}"
                                Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Settings]}"
                                Margin="2,0,0,0"
                                Padding="8,4"
                                Click="SettingsButton_Click"
                                ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_OpenSettings]}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ========== 主工作区 Grid：四列可调（左库 | 画布 | 属性 | AI面板） ========== -->
        <Grid Grid.Row="1" Margin="12,6,12,0">
            <Grid.ColumnDefinitions>
                <!-- 左侧节点库面板 -->
                <ColumnDefinition x:Name="LeftPanelColumn" Width="380" MinWidth="280" />
                <ColumnDefinition Width="Auto" />
                <!-- 中间画布+预览区 -->
                <ColumnDefinition Width="*" MinWidth="300" />
                <ColumnDefinition Width="Auto" />
                <!-- 右侧属性面板 -->
                <ColumnDefinition Width="220" MinWidth="160" />
                <ColumnDefinition Width="Auto" />
                <!-- AI 助手面板（仿 Claude 桌面版独立面板） -->
                <ColumnDefinition x:Name="AiPanelColumn" Width="400" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <!-- ===== 左侧面板：节点库 + 模板 ===== -->
            <Border Grid.Column="0"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource ControlCornerRadius}"
                    Padding="0">
                <TabControl x:Name="LeftPanelTabs"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Margin="0"
                            TabStripPlacement="Top">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Background" Value="{DynamicResource PanelBackground}" />
                            <Setter Property="Foreground" Value="{DynamicResource MutedText}" />
                            <Setter Property="Padding" Value="12,4" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="TabBorder"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{DynamicResource PanelBorder}"
                                                BorderThickness="0,0,0,1"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter ContentSource="Header"
                                                              RecognizesAccessKey="True" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource PanelBackground}" />
                                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource Accent}" />
                                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,0,0,2" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>
                    <!-- Tab 1: 节点库 -->
                    <TabItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_NodeLibrary]}">
                        <Grid Margin="12,8,12,12"
                              TextElement.Foreground="{DynamicResource PrimaryText}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="{DynamicResource PanelBackground}"
                                    BorderBrush="{DynamicResource ControlBorder}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Margin="0,0,0,6"
                                    Padding="6,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="NodeLibrarySearchBox"
                                             TextChanged="NodeLibrarySearchBox_TextChanged"
                                             Background="{DynamicResource PanelBackground}"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource PrimaryText}"
                                             CaretBrush="{DynamicResource PrimaryText}"
                                             FontSize="12"
                                             VerticalAlignment="Center">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Opacity" Value="0.7" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_SearchNodes]}"
                                               Foreground="{DynamicResource MutedText}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"
                                               Visibility="{Binding ElementName=NodeLibrarySearchBox, Path=Text, Converter={StaticResource StringToVisibilityConverter}}" />
                                    <Button Grid.Column="1"
                                            x:Name="ClearSearchButton"
                                            Content="X"
                                            FontSize="10"
                                            Width="18" Height="18"
                                            Padding="0"
                                            Background="Transparent"
                                            Foreground="{DynamicResource MutedText}"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="ClearSearchButton_Click"
                                            Visibility="Collapsed" />
                                </Grid>
                            </Border>
                            <!-- Thumbnail size slider -->
                            <Border Grid.Row="1"
                                    Background="{DynamicResource PanelBackground}"
                                    BorderBrush="{DynamicResource ControlBorder}"
                                    BorderThickness="1"
                                    CornerRadius="3"
                                    Margin="0,0,0,6"
                                    Padding="6,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="S"
                                               FontSize="9"
                                               Foreground="{DynamicResource MutedText}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,4,0" />
                                    <Slider Grid.Column="1"
                                            Minimum="28"
                                            Maximum="120"
                                            Value="{Binding Path=NodeThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                            TickFrequency="4"
                                            IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource Accent}"
                                            Thumb.DragCompleted="NodeThumbnailSlider_DragCompleted" />
                                    <TextBlock Grid.Column="2"
                                               Text="L"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource MutedText}"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0" />
                                </Grid>
                            </Border>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <!-- 分类树 -->
                                <TreeView Grid.Column="0"
                                          ItemsSource="{Binding NodeLibraryCategories}"
                                          SelectedItemChanged="NodeLibraryTree_SelectedItemChanged"
                                          Background="{DynamicResource PanelBackground}"
                                          Foreground="{DynamicResource PrimaryText}"
                                          BorderBrush="{DynamicResource ControlBorder}"
                                          BorderThickness="1"
                                          Padding="4">
                                    <TreeView.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" />
                                                <TextBlock Text="{Binding Count, StringFormat=' ({0})'}"
                                                           Foreground="{DynamicResource MutedText}"
                                                           FontSize="10"
                                                           Margin="4,0,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                                <!-- 节点列表（磁贴视图） -->
                                <ScrollViewer Grid.Column="2"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              PanningMode="Both"
                                              PanningDeceleration="0.002">
                                    <ListBox x:Name="NodeLibraryList"
                                             ItemContainerStyle="{StaticResource NodeLibraryTileItemStyle}"
                                             ItemTemplateSelector="{StaticResource NodeLibraryEntrySelector}"
                                             Background="{DynamicResource PanelBackground}"
                                             Foreground="{DynamicResource PrimaryText}"
                                             BorderBrush="{DynamicResource ControlBorder}"
                                             BorderThickness="1"
                                             Padding="4"
                                             PreviewMouseLeftButtonDown="NodeLibraryList_PreviewMouseLeftButtonDown"
                                             PreviewMouseMove="NodeLibraryList_PreviewMouseMove"
                                             SelectionChanged="NodeLibraryList_SelectionChanged"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             HorizontalContentAlignment="Stretch"
                                             VirtualizingPanel.IsVirtualizing="False">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel ItemWidth="{Binding Path=NodeThumbnailSize, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ThumbnailSizeConverter}}" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                    </ListBox>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </TabItem>
                    <!-- Tab 2: 模板浏览器 -->
                    <TabItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Templates]}">
                        <Grid Margin="12,8,12,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_DragTemplateHint]}"
                                       Foreground="{DynamicResource MutedText}"
                                       FontSize="11"
                                       Margin="0,0,0,8" />
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ListBox x:Name="TemplateList"
                                         ItemsSource="{Binding TemplateFiles}"
                                         Background="{DynamicResource PanelBackground}"
                                         Foreground="{DynamicResource PrimaryText}"
                                         BorderBrush="{DynamicResource ControlBorder}"
                                         BorderThickness="1"
                                         Padding="4"
                                         AllowDrop="True"
                                         PreviewMouseMove="TemplateList_PreviewMouseMove">
                                    <ListBox.Resources>
                                        <ContextMenu x:Key="TemplateContextMenu"
                                                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Rename]}"
                                                      Click="RenameTemplateMenuItem_Click" />
                                            <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Delete]}"
                                                      Click="DeleteTemplateMenuItem_Click" />
                                        </ContextMenu>
                                    </ListBox.Resources>
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="80" Height="80" Margin="4"
                                                    CornerRadius="4"
                                                    BorderBrush="{DynamicResource ControlBorder}"
                                                    BorderThickness="1"
                                                    Background="{DynamicResource WindowBackground}"
                                                    ContextMenu="{StaticResource TemplateContextMenu}">
                                                <Grid>
                                                    <Image Source="{Binding PreviewPath}"
                                                           Width="64" Height="64"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasPreview}" Value="False">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Foreground="{DynamicResource PrimaryText}"
                                                               FontSize="10"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Bottom"
                                                               Margin="2,0,2,2">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasPreview}" Value="False">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </ScrollViewer>
                            <Button Grid.Row="2"
                                    Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_SaveAsTemplate]}"
                                    Margin="0,8,0,0"
                                    Padding="4,4"
                                    Height="28"
                                    FontSize="11"
                                    Click="SaveAsTemplateMenuItem_Click"
                                    Style="{StaticResource MenuButton}" />
                        </Grid>
                    </TabItem>
                    <!-- Tab 3: Console -->
                    <TabItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Console]}"
                             x:Name="ConsoleTabItem">
                        <Grid Margin="12,8,12,12">
                            <controls:ConsoleControl x:Name="ConsoleControlHost" />
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <!-- 左侧分割条 -->
            <GridSplitter Grid.Column="1"
                          Width="2"
                          ResizeDirection="Columns"
                          Background="{DynamicResource PanelBorder}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ShowsPreview="True" />

            <!-- ===== 中间区域：节点画布 + 预览（上下可调） ===== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" MinHeight="150" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="2*" MinHeight="120" />
                </Grid.RowDefinitions>

                <!-- 节点画布 -->
                <Border Grid.Row="0"
                        Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}"
                        Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_NodeCanvas]}" Style="{StaticResource SectionTitle}" Margin="0" />
                            <TextBlock Grid.Column="1" Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_DragAndConnect]}" Foreground="{DynamicResource MutedText}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                            <!-- Animation playback controls -->
                            <Border Grid.Column="2" x:Name="AnimControlPanel"
                                    Background="{DynamicResource ControlBackground}"
                                    BorderBrush="{DynamicResource ControlBorder}"
                                    BorderThickness="1" CornerRadius="4"
                                    Padding="6,2" Margin="8,0,0,0"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="AnimPlayBtn" Content="▶" Width="22" Height="20" FontSize="10"
                                            Padding="0" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_AnimPlay]}"
                                            Click="AnimPlay_Click"
                                            Background="Transparent" Foreground="{DynamicResource PrimaryText}" BorderThickness="0" Cursor="Hand" />
                                    <Button x:Name="AnimStopBtn" Content="■" Width="20" Height="20" FontSize="9"
                                            Padding="0" Margin="2,0,0,0" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_AnimStop]}"
                                            Click="AnimStop_Click"
                                            Background="Transparent" Foreground="{DynamicResource MutedText}" BorderThickness="0" Cursor="Hand" />
                                    <Button x:Name="AnimStepBtn" Content="⏭" Width="20" Height="20" FontSize="9"
                                            Padding="0" Margin="2,0,0,0" ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_AnimNextFrame]}"
                                            Click="AnimStep_Click"
                                            Background="Transparent" Foreground="{DynamicResource MutedText}" BorderThickness="0" Cursor="Hand" />
                                    <Separator Width="1" Background="{DynamicResource ControlBorder}" Margin="4,2" />
                                    <TextBlock x:Name="AnimFrameLabel" Text="1/8"
                                               FontSize="10" VerticalAlignment="Center"
                                               Foreground="{DynamicResource MutedText}" Margin="0,0,4,0" />
                                    <TextBlock Text="FPS" FontSize="10"
                                               Foreground="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,2,0" />
                                    <ComboBox x:Name="AnimFpsCombo" Width="52" Height="18" FontSize="9"
                                              SelectedIndex="2" BorderThickness="1"
                                              SelectionChanged="AnimFpsCombo_SelectionChanged"
                                              Foreground="{DynamicResource PrimaryText}"
                                              Background="{DynamicResource ControlBackground}">
                                        <ComboBoxItem Content="6" Tag="6" />
                                        <ComboBoxItem Content="8" Tag="8" />
                                        <ComboBoxItem Content="12" Tag="12" />
                                        <ComboBoxItem Content="15" Tag="15" />
                                        <ComboBoxItem Content="24" Tag="24" />
                                        <ComboBoxItem Content="30" Tag="30" />
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <!-- 画布宿主：保留原有所有命名控件 -->
                        <Border x:Name="NodeCanvasHost"
                                Grid.Row="1"
                                Background="{DynamicResource WindowBackground}"
                                CornerRadius="{StaticResource ControlCornerRadius}"
                                Padding="4"
                                ClipToBounds="True"
                                AllowDrop="True"
                                DragOver="NodeCanvasHost_DragOver" 
                                Drop="NodeCanvasHost_Drop" 
                                PreviewMouseWheel="NodeCanvasHost_PreviewMouseWheel" 
                                PreviewMouseDown="NodeCanvasHost_PreviewMouseDown" 
                                PreviewMouseMove="NodeCanvasHost_PreviewMouseMove" 
                                PreviewMouseUp="NodeCanvasHost_PreviewMouseUp" 
                                PreviewMouseRightButtonUp="NodeCanvasHost_PreviewMouseRightButtonUp">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_SelectAll]}" Click="Context_SelectAll_Click" />
                                    <MenuItem Header="{Binding DeleteSelectedMenuHeader, Source={x:Static local:SettingsService.Hints}}" Click="Context_DeleteSelected_Click" />
                                    <Separator />
                                    <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_AutoArrangeNodes]}" Click="Context_AutoLayout_Click" />
                                    <Separator />
                                    <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_AddNodeNoise]}" Click="Context_AddNoiseNode_Click" />
                                </ContextMenu>
                            </Border.ContextMenu>
                            <!-- 画布视口（包含网格、连线、节点等）完全保留 -->
                            <Grid x:Name="NodeCanvasViewport">
                                <local:InfiniteGrid x:Name="InfiniteGrid"
                                                    Scale="{Binding NodeCanvasScale}"
                                                    OffsetX="{Binding NodeCanvasOffsetX}"
                                                    OffsetY="{Binding NodeCanvasOffsetY}"
                                                    MajorSpacing="64"
                                                    MinorSpacing="16"
                                                    MinorBrush="{StaticResource FineGridBrush}"
                                                    MajorBrush="{StaticResource CoarseGridBrush}"
                                                    Panel.ZIndex="0"
                                                    UseLayoutRounding="False"
                                                    SnapsToDevicePixels="False"
                                                    RenderOptions.BitmapScalingMode="Linear" />
                                <Rectangle x:Name="SelectionMarquee"
                                           Visibility="Collapsed"
                                           IsHitTestVisible="False"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top"
                                           Fill="#2066B2FF"
                                           Stroke="{DynamicResource Accent}"
                                           StrokeThickness="1"
                                           RadiusX="3"
                                           RadiusY="3"
                                           Panel.ZIndex="2" />
                                <!-- 语义控制面板 -->
                                <Border x:Name="SemanticControlPanel"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Stretch"
                                        Background="{DynamicResource PanelBackgroundAlt}"
                                        BorderBrush="{DynamicResource PanelBorder}"
                                        BorderThickness="0,0,0,1"
                                        Padding="8,4"
                                        Panel.ZIndex="10"
                                        Visibility="Collapsed">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedNode.Title, RelativeSource={RelativeSource AncestorType=Window}}" Value="语义控制">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                        <StackPanel Orientation="Horizontal">
                                            <ItemsControl ItemsSource="{Binding SelectedNode.Parameters, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Vertical" Margin="8,0" Width="90">
                                                            <StackPanel.Style>
                                                                <Style TargetType="StackPanel">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static local:NodeParameterKind.Boolean}">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </StackPanel.Style>
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       Foreground="{DynamicResource MutedText}"
                                                                       FontSize="10"
                                                                       TextAlignment="Center" />
                                                            <Slider Minimum="{Binding Min}"
                                                                    Maximum="{Binding Max}"
                                                                    SmallChange="0.01"
                                                                    LargeChange="0.1"
                                                                    Value="{Binding NumberValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    Height="18" />
                                                            <TextBlock Text="{Binding NumberValue, StringFormat=F2}"
                                                                       Foreground="{DynamicResource PrimaryText}"
                                                                       FontSize="10"
                                                                       TextAlignment="Center"
                                                                       PreviewMouseLeftButtonDown="NumberValueText_MouseDown"
                                                                       PreviewMouseMove="NumberValueText_MouseMove"
                                                                       PreviewMouseLeftButtonUp="NumberValueText_MouseUp"
                                                                       Cursor="SizeWE" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                                <Grid x:Name="NodeCanvasSurface" RenderTransformOrigin="0,0" Panel.ZIndex="1">
                                    <Grid.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="{Binding NodeCanvasScale}" ScaleY="{Binding NodeCanvasScale}" />
                                            <TranslateTransform X="{Binding NodeCanvasOffsetX}" Y="{Binding NodeCanvasOffsetY}" />
                                        </TransformGroup>
                                    </Grid.RenderTransform>
                                    <Canvas x:Name="NodeConnectionLayer"
                                            Panel.ZIndex="0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Top"
                                            Width="{Binding NodeCanvasWidth}"
                                            Height="{Binding NodeCanvasHeight}">
                                        <ItemsControl ItemsSource="{Binding NodeConnectionsView}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Canvas MouseLeftButtonDown="ConnectionLine_MouseLeftButtonDown">
                                                        <!-- 透明宽路径用于扩大点击区域 -->
                                                        <Path Data="{Binding WireGeometry}"
                                                              Stroke="Transparent"
                                                              StrokeThickness="10"
                                                              Fill="Transparent"
                                                              Cursor="Hand" />
                                                        <!-- 可见贝塞尔连线 -->
                                                        <Path Data="{Binding WireGeometry}"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              Fill="Transparent"
                                                              IsHitTestVisible="False">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Setter Property="Stroke" Value="#5CC8FF" />
                                                                    <Setter Property="StrokeThickness" Value="2" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Stroke" Value="#FFD966" />
                                                                            <Setter Property="StrokeThickness" Value="3" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Canvas>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Canvas>
                                    <ItemsControl x:Name="NodeCanvasItems" 
                                                  ItemsSource="{Binding NodeCanvasView}" 
                                                  Panel.ZIndex="1"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Top">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas x:Name="NodeCanvas"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Width="{Binding NodeCanvasWidth}"
                                                        Height="{Binding NodeCanvasHeight}" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource NodeBackground}"
                                                        CornerRadius="6"
                                                        Padding="6"
                                                        Width="180"
                                                        MouseLeftButtonDown="NodeItem_MouseLeftButtonDown"
                                                        MouseLeftButtonUp="NodeItem_MouseLeftButtonUp"
                                                        MouseMove="NodeItem_MouseMove">
                                                    <Border.ContextMenu>
                                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                            <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Rename]}" Click="Node_Context_Rename_Click" />
                                                            <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Copy]}" Click="Node_Context_Duplicate_Click" />
                                                            <MenuItem Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Delete]}" Click="Node_Context_Delete_Click" />
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource NodeBorder}" />
                                                            <Setter Property="BorderThickness" Value="1" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Accent}" />
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <Border Background="{DynamicResource NodeHeaderBackground}" CornerRadius="4" Padding="4" Margin="0,0,0,4">
                                                            <DockPanel>
                                                                <Border Width="24"
                                                                        Height="24"
                                                                        Background="{Binding PreviewBrush}"
                                                                        BorderBrush="{DynamicResource ControlBorder}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="3"
                                                                        Margin="0,0,6,0" />
                                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                            </DockPanel>
                                                        </Border>
                                                        <!-- Node center preview removed to simplify UI -->
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <ItemsControl ItemsSource="{Binding InputPorts}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,1">
                                                                            <Grid Width="14" Height="14" Margin="-13,0,3,0"
                                                                                  Background="Transparent" Cursor="Cross"
                                                                                  MouseEnter="NodePort_MouseEnter"
                                                                                  MouseLeave="NodePort_MouseLeave"
                                                                                  MouseLeftButtonDown="NodeInputPort_MouseLeftButtonDown"
                                                                                  MouseLeftButtonUp="NodeInputPort_MouseLeftButtonUp">
                                                                                <!-- Dark outline -->
                                                                                <Ellipse Stroke="#50000000" StrokeThickness="1" Fill="Transparent" IsHitTestVisible="False" />
                                                                                <!-- Main fill -->
                                                                                <Ellipse Margin="1" Fill="{Binding FillBrush}" IsHitTestVisible="False" />
                                                                                <!-- 3D convex gradient -->
                                                                                <Ellipse Margin="1" IsHitTestVisible="False">
                                                                                    <Ellipse.Fill>
                                                                                        <LinearGradientBrush StartPoint="0.3,0" EndPoint="0.7,1">
                                                                                            <GradientStop Color="#50FFFFFF" Offset="0" />
                                                                                            <GradientStop Color="#00FFFFFF" Offset="0.4" />
                                                                                            <GradientStop Color="#30000000" Offset="1" />
                                                                                        </LinearGradientBrush>
                                                                                    </Ellipse.Fill>
                                                                                </Ellipse>
                                                                            </Grid>
                                                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource MutedText}" VerticalAlignment="Center" />
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <ItemsControl Grid.Column="1" ItemsSource="{Binding OutputPorts}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,1" HorizontalAlignment="Right">
                                                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource MutedText}" Margin="0,0,3,0" VerticalAlignment="Center" />
                                                                            <Grid Width="14" Height="14" Margin="0,0,-13,0"
                                                                                  Background="Transparent" Cursor="Cross"
                                                                                  MouseEnter="NodePort_MouseEnter"
                                                                                  MouseLeave="NodePort_MouseLeave"
                                                                                  MouseLeftButtonDown="NodeOutputPort_MouseLeftButtonDown">
                                                                                <!-- Dark outline -->
                                                                                <Ellipse Stroke="#50000000" StrokeThickness="1" Fill="Transparent" IsHitTestVisible="False" />
                                                                                <!-- Main fill -->
                                                                                <Ellipse Margin="1" Fill="{Binding FillBrush}" IsHitTestVisible="False" />
                                                                                <!-- 3D convex gradient -->
                                                                                <Ellipse Margin="1" IsHitTestVisible="False">
                                                                                    <Ellipse.Fill>
                                                                                        <LinearGradientBrush StartPoint="0.3,0" EndPoint="0.7,1">
                                                                                            <GradientStop Color="#50FFFFFF" Offset="0" />
                                                                                            <GradientStop Color="#00FFFFFF" Offset="0.4" />
                                                                                            <GradientStop Color="#30000000" Offset="1" />
                                                                                        </LinearGradientBrush>
                                                                                    </Ellipse.Fill>
                                                                                </Ellipse>
                                                                            </Grid>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                                <TextBlock x:Name="NodeCanvasStats"
                                           IsHitTestVisible="False"
                                           Foreground="{DynamicResource MutedText}"
                                           Margin="8"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Top"
                                           FontSize="11"
                                           Text="-- ms · -- fps" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- 画布与预览之间的分割条 -->
                <GridSplitter Grid.Row="1"
                              Height="2"
                              ResizeDirection="Rows"
                              HorizontalAlignment="Stretch"
                              Background="{DynamicResource PanelBorder}"
                              ShowsPreview="True" />

                <!-- 预览区域 -->
                <Border Grid.Row="2"
                        Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}"
                        Padding="12">
                    <Grid x:Name="PreviewContentGrid" SizeChanged="PreviewGrid_SizeChanged">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <RadioButton x:Name="StillPreviewRadio"
                                             IsChecked="True"
                                             Style="{StaticResource PreviewTabRadioStyle}"
                                             Checked="StillPreviewRadio_Checked">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="12" Height="12" Margin="0,0,4,0">
                                            <Path Stroke="{DynamicResource PrimaryText}"
                                                  StrokeThickness="1.5"
                                                  StrokeLineJoin="Round"
                                                  Data="M2,2 L2,10 L6,10 L6,6 L10,6 L10,10 L14,10 L14,2 L2,2 Z" />
                                        </Viewbox>
                                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_StillFrame]}" />
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton x:Name="AnimPreviewRadio"
                                             Margin="4,0,0,0"
                                             Style="{StaticResource PreviewTabRadioStyle}"
                                             Checked="AnimPreviewRadio_Checked">
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="12" Height="12" Margin="0,0,4,0">
                                            <Path Stroke="{DynamicResource PrimaryText}"
                                                  StrokeThickness="1.5"
                                                  StrokeLineJoin="Round"
                                                  Data="M2,2 L6,6 L2,10 M8,2 L12,6 L8,10" />
                                        </Viewbox>
                                        <TextBlock Text="动画" />
                                    </StackPanel>
                                </RadioButton>
                                <TextBlock x:Name="ZoomText" Text="100%" Foreground="{DynamicResource MutedText}" Margin="12,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button x:Name="ZoomResetButton"
                                        ToolTip="{Binding FitPreviewToolTip, Source={x:Static local:SettingsService.Hints}}"
                                        Width="32"
                                        Height="28"
                                        Margin="0,0,6,0"
                                        Click="ZoomResetButton_Click"
                                        Style="{StaticResource MenuButton}">
                                    <Viewbox Width="16" Height="16">
                                        <Path Stroke="{DynamicResource PrimaryText}"
                                              StrokeThickness="1.8"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Fill="Transparent"
                                              Data="M5,1 L1,1 L1,5  M11,1 L15,1 L15,5  M5,15 L1,15 L1,11  M11,15 L15,15 L15,11" />
                                    </Viewbox>
                                </Button>
                                <ToggleButton x:Name="PreviewGridToggleButton"
                                              ToolTip="{Binding TogglePreviewGridToolTip, Source={x:Static local:SettingsService.Hints}}"
                                              Width="36"
                                              Height="26"
                                              Margin="0,0,6,0"
                                              Click="PreviewGridToggleButton_Click"
                                              Style="{StaticResource MenuToggleButton}">
                                    <Grid Width="15" Height="15" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Grid.RowDefinitions>
                                            <RowDefinition />
                                            <RowDefinition />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Row="0" Grid.Column="0" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="0" Grid.Column="1" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="0" Grid.Column="2" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="1" Grid.Column="0" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="1" Grid.Column="1" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="1" Grid.Column="2" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="2" Grid.Column="0" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="2" Grid.Column="1" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                        <Rectangle Grid.Row="2" Grid.Column="2" Fill="{DynamicResource PrimaryText}" Margin="1" />
                                    </Grid>
                                </ToggleButton>
                                <ToggleButton x:Name="TileToggleButton"
                                              ToolTip="{Binding ToggleTilePreviewToolTip, Source={x:Static local:SettingsService.Hints}}"
                                              Width="36"
                                              Height="26"
                                              Margin="0,0,6,0"
                                              Click="TileToggleButton_Click"
                                              Style="{StaticResource MenuToggleButton}">
                                    <TextBlock Text="▦" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </ToggleButton>
                                <Separator Width="1" Background="{DynamicResource ControlBorder}" Margin="4,2" />
                                <ToggleButton x:Name="ComparisonToggleButton"
                                              ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_ComparisonMode]}"
                                              Width="36"
                                              Height="26"
                                              Margin="0,0,0,0"
                                              Click="ComparisonToggleButton_Click"
                                              Style="{StaticResource MenuToggleButton}">
                                    <Grid Width="14" Height="14">
                                        <Rectangle Fill="{DynamicResource PrimaryText}" Opacity="0.9">
                                            <Rectangle.OpacityMask>
                                                <VisualBrush Stretch="Fill">
                                                    <VisualBrush.Visual>
                                                        <Rectangle Width="14" Height="14" Fill="White" />
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                        <Line X1="7" Y1="0" X2="7" Y2="14" Stroke="{DynamicResource PanelBackground}" StrokeThickness="1.5" />
                                    </Grid>
                                </ToggleButton>
                            </StackPanel>
                        </Grid>

                        <!-- Frame slider bar for Still mode (hidden by default) -->
                        <Border x:Name="StillFrameSliderBar"
                                Grid.Row="1"
                                Background="{DynamicResource ControlBackground}"
                                BorderBrush="{DynamicResource ControlBorder}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="8,2"
                                Margin="0,0,0,6"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Frame]}" FontSize="10"
                                           Foreground="{DynamicResource MutedText}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <Slider x:Name="StillFrameSlider"
                                        Grid.Column="1"
                                        Minimum="0"
                                        Maximum="1"
                                        Value="0"
                                        SmallChange="0.01"
                                        LargeChange="0.1"
                                        ValueChanged="StillFrameSlider_ValueChanged"
                                        VerticalAlignment="Center" />
                                <TextBlock x:Name="StillFrameLabel"
                                           Grid.Column="2"
                                           Text="1/1"
                                           FontSize="10"
                                           Foreground="{DynamicResource MutedText}"
                                           VerticalAlignment="Center"
                                           Margin="6,0,0,0" />
                            </Grid>
                        </Border>

                        <Border x:Name="PreviewViewport"
                                Grid.Row="2"
                                Background="{DynamicResource WindowBackground}"
                                CornerRadius="{StaticResource ControlCornerRadius}"
                                ClipToBounds="True"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Padding="8"
                                MouseWheel="PreviewContainer_MouseWheel">
                            <Grid x:Name="PreviewContainer"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  RenderTransformOrigin="0.5,0.5"
                                  RenderOptions.BitmapScalingMode="NearestNeighbor">
                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="PreviewScale" ScaleX="1" ScaleY="1" />
                                </Grid.RenderTransform>
                                <Rectangle x:Name="TiledPreviewSurface"
                                           Visibility="Collapsed"
                                           Stretch="Fill"
                                           SnapsToDevicePixels="True"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                <Image x:Name="PreviewImage"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                <Rectangle x:Name="PreviewPixelGridSurface"
                                           Visibility="Collapsed"
                                           IsHitTestVisible="False"
                                           SnapsToDevicePixels="True"
                                           RenderOptions.BitmapScalingMode="Linear"
                                           Panel.ZIndex="2"
                                           Fill="{StaticResource PreviewPixelGridBrush}"
                                           RenderOptions.EdgeMode="Aliased" />
                                <!-- Overlay for real-time preview pixel grid -->
                                <!-- Comparison mode: terminal node output when split enabled -->
                                <Image x:Name="ComparisonImage"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                <Rectangle x:Name="ComparisonDivider"
                                           Width="1"
                                           Fill="{DynamicResource PanelBorder}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Stretch"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- 中间分割条（中/右） -->
            <GridSplitter Grid.Column="3"
                          Width="2"
                          ResizeDirection="Columns"
                          Background="{DynamicResource PanelBorder}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ShowsPreview="True" />

            <!-- ===== 右侧面板：三个可调整大小的垂直面板 ===== -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MinHeight="100" />
                    <!-- 全局设置 -->
                    <RowDefinition Height="Auto" />
                    <!-- 分割条 -->
                    <RowDefinition Height="2*" MinHeight="150" />
                    <!-- 节点属性 -->
                    <RowDefinition Height="Auto" />
                    <!-- 分割条 -->
                    <RowDefinition Height="*" MinHeight="160" />
                    <!-- 节点列表 -->
                </Grid.RowDefinitions>

                <!-- 全局设置面板 -->
                <Border Grid.Row="0"
                        Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}"
                        Padding="12">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_GlobalSettings]}" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_TileSize]}" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ComboBox x:Name="TileSizeCombo" SelectedIndex="1" Margin="0,0,0,8" SelectionChanged="ParameterChanged">
                            <ComboBoxItem Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_16px], Mode=OneTime}" Tag="16" />
                            <ComboBoxItem Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_32px], Mode=OneTime}" Tag="32" />
                            <ComboBoxItem Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_64px], Mode=OneTime}" Tag="64" />
                            <!-- 128px removed: large pixel-art tiles produce poor results and are not commonly used -->
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- 分割条1 -->
                <GridSplitter Grid.Row="1"
                              Height="2"
                              ResizeDirection="Rows"
                              HorizontalAlignment="Stretch"
                              Background="{DynamicResource PanelBorder}"
                              ShowsPreview="True" />

                <!-- 节点属性面板（原有结构完整保留） -->
                <Border Grid.Row="2"
                        Background="{DynamicResource PanelBackground}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource ControlCornerRadius}"
                        MinHeight="0"
                        Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="127*"/>
                            <ColumnDefinition Width="67*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_NodeProperties]}" Style="{StaticResource SectionTitle}" Margin="0,0,0,8" Grid.Row="0" Grid.ColumnSpan="2" />

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Grid.ColumnSpan="2"
                                      PanningMode="Both" PanningDeceleration="0.002">
                            <StackPanel Margin="0,0,8,8">
                                <ContentControl Content="{Binding SelectedNode, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Style.Triggers>
                                                <Trigger Property="Content" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                    <ContentControl.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <TextBlock Text="{Binding SelectedNode.RegistryKey, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource NodeDescriptionConverter}}"
                                                           Style="{StaticResource FieldLabel}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource MutedText}"
                                                           FontSize="11"
                                                           Margin="0,0,0,8" />
                                                <Expander Header="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_NodeParameters]}" IsExpanded="True">
                                                    <Expander.Style>
                                                        <Style TargetType="Expander" BasedOn="{StaticResource {x:Type Expander}}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedNode.Parameters.Count, RelativeSource={RelativeSource AncestorType=Window}}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Expander.Style>
                                                    <ItemsControl ItemsSource="{Binding SelectedNode.Parameters, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="0,0,0,8">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding DisplayName}" Style="{StaticResource FieldLabel}" />
                                                                        <Button Grid.Column="1"
                                                                                Content="↩"
                                                                                ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_ResetParam]}"
                                                                                Width="20" Height="20"
                                                                                FontSize="12"
                                                                                Padding="0"
                                                                                Tag="{Binding}"
                                                                                Click="NodeParamReset_Click"
                                                                                Style="{StaticResource MenuButton}" />
                                                                    </Grid>

                                                                    <Grid>
                                                                        <Grid.Style>
                                                                            <Style TargetType="Grid">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static local:NodeParameterKind.Number}">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Grid.Style>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <Slider Minimum="{Binding Min}"
                                                                                Maximum="{Binding Max}"
                                                                                TickFrequency="{Binding Step}"
                                                                                Value="{Binding NumberValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                        <TextBox Grid.Column="1"
                                                                                 Style="{StaticResource RangeInputTextBox}"
                                                                                 Text="{Binding NumberValue, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                                    </Grid>

                                                                    <Grid>
                                                                        <Grid.Style>
                                                                            <Style TargetType="Grid">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static local:NodeParameterKind.Integer}">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Grid.Style>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <Slider Minimum="{Binding Min}"
                                                                                Maximum="{Binding Max}"
                                                                                TickFrequency="{Binding Step}"
                                                                                IsSnapToTickEnabled="True"
                                                                                Value="{Binding IntValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                        <TextBox Grid.Column="1"
                                                                                 Style="{StaticResource RangeInputTextBox}"
                                                                                 Text="{Binding IntValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                    </Grid>

                                                                    <ComboBox ItemsSource="{Binding DisplayChoices}"
                                                                              SelectedItem="{Binding SelectedDisplayChoice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                                        <ComboBox.Style>
                                                                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static local:NodeParameterKind.Choice}">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </ComboBox.Style>
                                                                    </ComboBox>

                                                                    <TextBox Text="{Binding TextValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                             AcceptsReturn="False"
                                                                             Padding="6,4"
                                                                             Width="180"
                                                                             FontSize="12"
                                                                             HorizontalAlignment="Left"
                                                                             HorizontalContentAlignment="Left">
                                                                        <TextBox.Style>
                                                                            <Style TargetType="TextBox">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static local:NodeParameterKind.Text}">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBox.Style>
                                                                    </TextBox>

                                                                    <CheckBox Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_Enable]}"
                                                                              IsChecked="{Binding BoolValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                                        <CheckBox.Style>
                                                                            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static local:NodeParameterKind.Boolean}">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </CheckBox.Style>
                                                                    </CheckBox>

                                                                    <!-- PointList: 绘制自定义形状按钮 -->
                                                                    <Button Content="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_DrawCustomShape]}"
                                                                            Click="OpenShapeDrawingWindow_Click"
                                                                            Tag="{Binding}"
                                                                            Padding="6,4" Margin="0,2,0,0"
                                                                            Background="{DynamicResource ControlBackground}"
                                                                            Foreground="{DynamicResource PrimaryText}"
                                                                            BorderBrush="{DynamicResource Accent}">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static local:NodeParameterKind.PointList}">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                    </Button>

                                                                    <!-- Color: 色环取色 -->
                                                                    <Grid Margin="0,2,0,0">
                                                                        <Grid.Style>
                                                                            <Style TargetType="Grid">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static local:NodeParameterKind.Color}">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Grid.Style>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto" />
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Width="28" Height="24"
                                                                                BorderBrush="{DynamicResource ControlBorder}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="3"
                                                                                VerticalAlignment="Center">
                                                                            <Rectangle Fill="{Binding ColorValue, Converter={StaticResource ColorToBrushConverter}}" RadiusX="2" RadiusY="2" />
                                                                        </Border>
                                                                        <TextBox Grid.Column="1"
                                                                                 Margin="6,0,6,0"
                                                                                 VerticalContentAlignment="Center"
                                                                                 IsReadOnly="True"
                                                                                 Text="{Binding ColorValue, Converter={StaticResource ColorToHexConverter}, Mode=OneWay}" />
                                                                        <Button Grid.Column="2"
                                                                                Content="🎨"
                                                                                ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_OpenColorWheel]}"
                                                                                Width="28" Height="24"
                                                                                Tag="{Binding}"
                                                                                Click="OpenColorWheelForParameter_Click"
                                                                                Style="{StaticResource MenuButton}" />
                                                                    </Grid>

                                                                    <!-- Seed: 种子输入 + 骰子按钮 -->
                                                                    <Grid>
                                                                        <Grid.Style>
                                                                            <Style TargetType="Grid">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static local:NodeParameterKind.Seed}">
                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Grid.Style>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBox Text="{Binding IntValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                        <Button Grid.Column="1"
                                                                                Content="🎲"
                                                                                ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_RandomizeSeed]}"
                                                                                Width="28"
                                                                                Height="24"
                                                                                Margin="6,0,0,0"
                                                                                Tag="{Binding}"
                                                                                Click="NodeParamSeedRandom_Click"
                                                                                Style="{StaticResource MenuButton}" />
                                                                    </Grid>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Expander>

                                                <!-- ===== 草地参数 ===== -->
                                                <Expander IsExpanded="True">
                                                    <Expander.Header>
                                                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_GrassParameters]}" Foreground="{DynamicResource PrimaryText}" FontWeight="SemiBold" />
                                                    </Expander.Header>
                                                    <Expander.Style>
                                                        <Style TargetType="Expander">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedNode.TileType, RelativeSource={RelativeSource AncestorType=Window}}" Value="{x:Static local:TileType.Grass}">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Expander.Style>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_RandomSeed]}" Style="{StaticResource FieldLabel}" />
                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Tag="{x:Static local:TileType.Grass}"
                                                                     Text="{Binding ActiveTileProperties.Seed, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     PreviewTextInput="SeedTextBox_PreviewTextInput"
                                                                     DataObject.Pasting="SeedTextBox_Pasting"
                                                                     LostFocus="SeedTextBox_LostFocus" />
                                                            <Button Grid.Column="1"
                                                                    Tag="{x:Static local:TileType.Grass}"
                                                                    Content="🎲"
                                                                    ToolTip="{Binding Source={x:Static loc:LocalizationService.Instance}, Path=[MW_RandomizeSeed]}"
                                                                    Width="28"
                                                                    Height="24"
                                                                    Margin="6,0,0,0"
                                                                    Click="SeedRandomButton_Click"
                                                                    Style="{StaticResource MenuButton}" />
                                                        </Grid>

